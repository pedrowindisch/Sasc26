@{
    ViewData["Title"] = "Registrar Presença";
    var activeSession = ViewBag.ActiveSession as string;
    var hasActiveSession = (bool)ViewBag.HasActiveSession;
}

@section Styles {
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: #f5f5f5;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .card-wrapper {
            width: 100%;
            max-width: 440px;
            padding: 0 16px;
        }

        .event-card {
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.06);
            overflow: hidden;
        }

        .event-header {
            background: #113D76;
            padding: 28px 24px 20px;
            text-align: center;
        }

        .event-header img.logo {
            width: 56px;
            height: 56px;
            margin-bottom: 12px;
        }

        .event-header h1 {
            font-size: 1.25rem;
            font-weight: 700;
            color: #fff;
            margin: 0;
        }

        .event-header p {
            font-size: 0.75rem;
            color: rgba(255,255,255,0.6);
            margin: 4px 0 0;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .session-tag {
            display: inline-block;
            margin-top: 12px;
            padding: 4px 14px;
            border-radius: 100px;
            font-size: 0.75rem;
            font-weight: 600;
        }

        .session-tag.active { background: rgba(46,189,239,0.2); color: #2EBDEF; }
        .session-tag.inactive { background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.5); }

        .event-body { padding: 8px 24px 28px; }

        .otp-input {
            letter-spacing: 6px;
            font-size: 1.25rem;
            font-weight: 600;
            text-align: center;
        }

        .step-section { display: none; padding-top: 16px; }
        .step-section.active { display: block; }

        .msg-error {
            background: #fef2f2;
            color: #b91c1c;
            padding: 10px 14px;
            border-radius: 8px;
            font-size: 0.85rem;
            margin-bottom: 16px;
        }

        .msg-success {
            background: #ecfdf5;
            color: #047857;
            padding: 10px 14px;
            border-radius: 8px;
            font-size: 0.85rem;
            margin-bottom: 16px;
        }

        .back-link {
            display: inline-block;
            margin-top: 12px;
            font-size: 0.8rem;
            color: #aaa;
            cursor: pointer;
        }

        .back-link:hover { color: #555; }

        .email-hint {
            font-size: 0.8rem;
            color: #999;
            margin-bottom: 16px;
        }

        .field + .field { margin-top: 12px; }

        .section-divider {
            border: none;
            border-top: 1px solid #eee;
            margin: 20px 0;
        }

        .section-label {
            font-size: 0.7rem;
            font-weight: 600;
            color: #bbb;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            margin-bottom: 12px;
        }

        .button.is-brand {
            background-color: #fff;
            color: #113D76;
        }

        .button.is-brand:hover {
            background-color: #f0f0f0;
            color: #113D76;
        }

        .input:focus, .select select:focus {
            border-color: #2EBDEF;
            box-shadow: 0 0 0 3px rgba(46,189,239,0.15);
        }
    </style>
    <link rel="stylesheet" href="~/css/bulmaswatch.min.css">
}

<div class="card-wrapper">
    <div class="event-card">
        <div class="event-header">
            <img class="logo" src="~/dasc.svg" alt="DASC">
            <h1>SASC 26</h1>
            <p>Semana Acadêmica de Sistemas e Computação</p>
            @if (hasActiveSession)
            {
                <span class="session-tag active">@activeSession</span>
            }
            else
            {
                <span class="session-tag inactive">Nenhuma sessão ativa</span>
            }
        </div>

        <div class="event-body">
            <div id="messageArea"></div>

            <div class="step-section active" id="stepEmail">
                <div class="field">
                    <label class="label is-small has-text-grey">E-mail institucional</label>
                    <div class="control">
                        <input class="input" type="email" id="emailInput"
                               placeholder="seu.nome@furb.br"
                               autocomplete="email" autofocus>
                    </div>
                </div>
                <div class="field" style="margin-top:16px;">
                    <div class="control">
                        <button class="button is-brand is-fullwidth" id="btnSendOtp" onclick="requestOtp()">
                            Enviar código
                        </button>
                    </div>
                </div>
            </div>

            <div class="step-section" id="stepOtp">
                <p class="email-hint" id="emailDisplay"></p>

                <div class="field">
                    <label class="label is-small has-text-grey">Código de verificação</label>
                    <div class="control">
                        <input class="input otp-input" type="text" id="otpInput"
                               maxlength="6" inputmode="numeric" pattern="[0-9]*"
                               placeholder="000000" autocomplete="one-time-code">
                    </div>
                </div>

                <hr class="section-divider">
                <p class="section-label">Dados cadastrais</p>

                <div class="field">
                    <label class="label is-small has-text-grey">Nome completo</label>
                    <div class="control">
                        <input class="input" type="text" id="fullNameInput"
                               placeholder="João da Silva" autocomplete="name">
                    </div>
                </div>

                <div class="field">
                    <label class="label is-small has-text-grey">Curso</label>
                    <div class="control">
                        <div class="select is-fullwidth">
                            <select id="courseSelect">
                                <option value="">Selecione</option>
                                <option value="Ciência da Computação">Ciência da Computação</option>
                                <option value="Ciência de Dados">Ciência de Dados</option>
                                <option value="Sistemas de Informação">Sistemas de Informação</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="field">
                    <label class="label is-small has-text-grey">Turno</label>
                    <div class="control">
                        <div class="select is-fullwidth">
                            <select id="shiftSelect">
                                <option value="">Selecione</option>
                                <option value="Matutino">Matutino</option>
                                <option value="Noturno">Noturno</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="field">
                    <label class="label is-small has-text-grey">Fase</label>
                    <div class="control">
                        <div class="select is-fullwidth">
                            <select id="phaseSelect">
                                <option value="">-</option>
                                @for (var i = 1; i <= 9; i++)
                                {
                                    <option value="@i">@i</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>

                <div class="field" style="margin-top:16px;">
                    <div class="control">
                        <button class="button is-brand is-fullwidth" id="btnVerify" onclick="verifyOtp()">
                            Confirmar presença
                        </button>
                    </div>
                </div>
                <a class="back-link" onclick="goBack()">&#8592; Voltar</a>
            </div>

            <div class="step-section" id="stepSuccess">
                <div class="msg-success has-text-centered" id="successMessage" style="padding:16px;"></div>
                <div class="has-text-centered">
                    <a class="back-link" onclick="resetForm()">&#8592; Voltar ao início</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let currentEmail = '';

    function showMessage(text, type) {
        document.getElementById('messageArea').innerHTML = `<div class="msg-${type}">${text}</div>`;
    }

    function clearMessage() {
        document.getElementById('messageArea').innerHTML = '';
    }

    function showStep(step) {
        document.querySelectorAll('.step-section').forEach(el => el.classList.remove('active'));
        document.getElementById('step' + step).classList.add('active');
    }

    async function loadProfile(email) {
        try {
            const res = await fetch(`/Home/GetProfile?email=${encodeURIComponent(email)}`);
            const data = await res.json();
            if (data && data.found) {
                document.getElementById('fullNameInput').value = data.fullName || '';
                document.getElementById('courseSelect').value = data.course || '';
                document.getElementById('shiftSelect').value = data.shift || '';
                document.getElementById('phaseSelect').value = data.phase || '';
            }
        } catch {}
    }

    async function requestOtp() {
        const email = document.getElementById('emailInput').value.trim();
        if (!email) { showMessage('Informe seu e-mail.', 'error'); return; }

        clearMessage();
        const btn = document.getElementById('btnSendOtp');
        btn.classList.add('is-loading');
        btn.disabled = true;

        try {
            const res = await fetch('/Home/RequestOtp', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email })
            });
            const data = await res.json();
            if (data.success) {
                currentEmail = email;
                document.getElementById('emailDisplay').textContent = email;
                showStep('Otp');
                document.getElementById('otpInput').focus();
                loadProfile(email);
            } else {
                showMessage(data.message, 'error');
            }
        } catch {
            showMessage('Erro de conexão.', 'error');
        } finally {
            btn.classList.remove('is-loading');
            btn.disabled = false;
        }
    }

    async function verifyOtp() {
        const code = document.getElementById('otpInput').value.trim();
        if (!code || code.length !== 6) { showMessage('Digite o código de 6 dígitos.', 'error'); return; }

        const fullName = document.getElementById('fullNameInput').value.trim();
        const course = document.getElementById('courseSelect').value;
        const shift = document.getElementById('shiftSelect').value;
        const phase = parseInt(document.getElementById('phaseSelect').value) || 0;

        if (!fullName) { showMessage('Informe seu nome completo.', 'error'); return; }
        if (!course) { showMessage('Selecione o curso.', 'error'); return; }
        if (!shift) { showMessage('Selecione o turno.', 'error'); return; }
        if (phase < 1) { showMessage('Selecione a fase.', 'error'); return; }

        clearMessage();
        const btn = document.getElementById('btnVerify');
        btn.classList.add('is-loading');
        btn.disabled = true;

        try {
            const res = await fetch('/Home/VerifyOtp', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    email: currentEmail, code,
                    fullName, course, shift, phase
                })
            });
            const data = await res.json();
            if (data.success) {
                clearMessage();
                document.getElementById('successMessage').textContent = data.message;
                showStep('Success');
            } else {
                showMessage(data.message, 'error');
            }
        } catch {
            showMessage('Erro de conexão.', 'error');
        } finally {
            btn.classList.remove('is-loading');
            btn.disabled = false;
        }
    }

    function goBack() {
        clearMessage();
        showStep('Email');
        document.getElementById('otpInput').value = '';
    }

    function resetForm() {
        clearMessage();
        document.getElementById('emailInput').value = '';
        document.getElementById('otpInput').value = '';
        document.getElementById('fullNameInput').value = '';
        document.getElementById('courseSelect').value = '';
        document.getElementById('shiftSelect').value = '';
        document.getElementById('phaseSelect').value = '';
        currentEmail = '';
        showStep('Email');
    }

    document.getElementById('emailInput').addEventListener('keydown', e => { if (e.key === 'Enter') requestOtp(); });
    document.getElementById('otpInput').addEventListener('keydown', e => { if (e.key === 'Enter') verifyOtp(); });
    document.getElementById('otpInput').addEventListener('input', e => { e.target.value = e.target.value.replace(/\D/g, '').slice(0, 6); });
</script>
}
