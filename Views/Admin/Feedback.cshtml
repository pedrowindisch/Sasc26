@{
    ViewData["Title"] = "Avaliações das Palestras";
    Layout = null;
    var summaries = ViewBag.FeedbackSummaries as List<Sasc26.Models.LectureFeedbackSummaryDto> ?? new();
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SASC 26</title>
    <link rel="stylesheet" href="~/css/bulmaswatch.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background: #f5f5f5; min-height: 100vh; }
        .nav-bar { background: #113D76; padding: 16px 24px; display: flex; align-items: center; gap: 16px; }
        .nav-logo { display: flex; align-items: center; gap: 12px; flex: 1; }
        .nav-logo img { height: 32px; }
        .nav-logo h1 { font-size: 1rem; font-weight: 700; color: #fff; margin: 0; }
        .nav-links { display: flex; gap: 16px; align-items: center; }
        .nav-links a { font-size: 0.8rem; color: #2EBDEF; }
        .nav-links a:hover { color: #fff; }
        .nav-links a.nav-logout { color: rgba(255,255,255,0.6); }
        .nav-links a.nav-logout:hover { color: #fff; }
        .container-area { max-width: 1100px; margin: 0 auto; padding: 24px 16px; }
        .panel-card { background: #fff; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); padding: 24px; margin-bottom: 20px; }
        .panel-card h2 { font-size: 0.95rem; font-weight: 700; color: #1a1a1a; margin: 0 0 16px; }
        .table { font-size: 0.82rem; }
        .table th { font-weight: 600; color: #555; }
        .stars { color: #f59e0b; letter-spacing: 1px; }
        .stars-dim { color: #d1d5db; letter-spacing: 1px; }
        .badge { display: inline-block; padding: 2px 10px; border-radius: 100px; font-size: 0.7rem; font-weight: 600; }
        .badge-ok { background: #ecfdf5; color: #059669; }
        .badge-warn { background: #fffbeb; color: #92400e; }
        .badge-skip { background: #f3f4f6; color: #9ca3af; }
        .avg-rating { font-size: 1.4rem; font-weight: 700; color: #113D76; }
        .avg-label { font-size: 0.7rem; color: #999; text-transform: uppercase; }
        .stats-row { display: flex; gap: 12px; margin-bottom: 16px; }
        .stat-box { background: #f9fafb; border-radius: 8px; padding: 12px 16px; text-align: center; flex: 1; }
        .stat-box .num { font-size: 1.2rem; font-weight: 700; color: #113D76; }
        .stat-box .lbl { font-size: 0.65rem; color: #999; text-transform: uppercase; letter-spacing: 0.05em; }
        .button.is-brand { background-color: #fff; color: #113D76; }
        .button.is-brand:hover { background-color: #f0f0f0; color: #113D76; }
        .detail-toggle { cursor: pointer; color: #2EBDEF; font-size: 0.78rem; }
        .detail-toggle:hover { text-decoration: underline; }
        .feedback-list { display: none; margin-top: 12px; }
        .feedback-list.open { display: block; }
        .feedback-entry { background: #f9fafb; border-radius: 8px; padding: 10px 14px; margin-bottom: 8px; }
        .feedback-entry .fe-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px; }
        .feedback-entry .fe-email { font-size: 0.78rem; color: #666; }
        .feedback-entry .fe-comment { font-size: 0.82rem; color: #333; }
        .feedback-entry .fe-date { font-size: 0.7rem; color: #aaa; }
        .empty-state { text-align: center; padding: 24px; color: #bbb; font-size: 0.85rem; }
    </style>
</head>
<body>
    <div class="nav-bar">
        <div class="nav-logo">
            <img src="~/dasc.svg" alt="DASC">
            <h1>Avaliações das Palestras</h1>
        </div>
        <div class="nav-links">
            <a href="/Admin/Dashboard">&#8592; Dashboard</a>
            <a href="/Admin/Logout" class="nav-logout">Sair</a>
        </div>
    </div>

    <div class="container-area">
        @if (summaries.Count == 0)
        {
            <div class="panel-card">
                <div class="empty-state">Nenhuma avaliação registrada ainda.</div>
            </div>
        }
        else
        {
            @foreach (var s in summaries)
            {
                <div class="panel-card">
                    <div style="display:flex;justify-content:space-between;align-items:flex-start;">
                        <div>
                            <h2 style="margin-bottom:4px;">@s.Title</h2>
                            <p style="font-size:0.82rem;color:#888;margin:0 0 12px;">Palestrante: @s.Speaker</p>
                        </div>
                        <div class="stat-box" style="flex:none;min-width:80px;">
                            <div class="avg-rating">@s.AverageRating.ToString("0.0")</div>
                            <div class="avg-label">Média</div>
                        </div>
                    </div>
                    <div class="stats-row">
                        <div class="stat-box"><div class="num">@s.TotalResponses</div><div class="lbl">Respostas</div></div>
                        <div class="stat-box"><div class="num">@((s.TotalResponses - s.TotalSkipped) > 0 ? Math.Round((double)(s.TotalResponses - s.TotalSkipped) / s.TotalResponses * 100) : 0)%</div><div class="lbl">Avaliaram</div></div>
                        <div class="stat-box"><div class="num">@s.TotalSkipped</div><div class="lbl">Pularam</div></div>
                    </div>
                    <span class="detail-toggle" onclick="toggleDetail(@s.LectureId)">Ver respostas detalhadas &#9662;</span>
                    <div class="feedback-list" id="detail-@s.LectureId">
                        @foreach (var f in s.Feedbacks)
                        {
                            <div class="feedback-entry">
                                <div class="fe-header">
                                    <span class="fe-email">@f.AttendeeEmail</span>
                                    @if (f.Skipped)
                                    {
                                        <span class="badge badge-skip">Pulou</span>
                                    }
                                    else
                                    {
                                        <span class="stars">@string.Concat(Enumerable.Repeat("★", f.Rating))</span><span class="stars-dim">@string.Concat(Enumerable.Repeat("★", 5 - f.Rating))</span>
                                    }
                                </div>
                                @if (!string.IsNullOrWhiteSpace(f.Comment))
                                {
                                    <p class="fe-comment" style="margin:4px 0;">"@f.Comment"</p>
                                }
                                <span class="fe-date">@f.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                        }
                    </div>
                </div>
            }
        }
    </div>

    <script>
        function toggleDetail(id) {
            const el = document.getElementById('detail-' + id);
            el.classList.toggle('open');
        }
    </script>
</body>
</html>