@{
    ViewData["Title"] = "Painel do Administrador";
    Layout = null;
    var timeSlots = ViewBag.TimeSlots as List<Sasc26.Models.TimeSlot> ?? new();
    var lectures = ViewBag.Lectures as List<Sasc26.Models.Lecture> ?? new();
    var preRegCounts = ViewBag.PreRegCounts as Dictionary<int, int> ?? new();
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SASC 26</title>
    <link rel="stylesheet" href="~/css/bulmaswatch.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background: #f5f5f5; min-height: 100vh; }
        .nav-bar { background: #113D76; padding: 16px 24px; display: flex; align-items: center; gap: 16px; }
        .nav-logo { display: flex; align-items: center; gap: 12px; flex: 1; }
        .nav-logo img { height: 32px; }
        .nav-logo h1 { font-size: 1rem; font-weight: 700; color: #fff; margin: 0; }
        .nav-links { display: flex; gap: 16px; align-items: center; }
        .nav-links a { font-size: 0.8rem; color: #2EBDEF; }
        .nav-links a:hover { color: #fff; }
        .nav-links a.nav-logout { color: rgba(255,255,255,0.6); }
        .nav-links a.nav-logout:hover { color: #fff; }
        .container-area { max-width: 1200px; margin: 0 auto; padding: 24px 16px; }
        .panel-card { background: #fff; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); padding: 24px; margin-bottom: 20px; }
        .panel-card h2 { font-size: 0.95rem; font-weight: 700; color: #1a1a1a; margin: 0 0 16px; }
        .input:focus, .select select:focus { border-color: #2EBDEF; box-shadow: 0 0 0 3px rgba(46,189,239,0.15); }
        .button.is-brand { background-color: #fff; color: #113D76; }
        .button.is-brand:hover { background-color: #f0f0f0; color: #113D76; }
        .button.is-outlined-brand { background-color: transparent; color: #113D76; border: 1px solid #113D76; }
        .button.is-outlined-brand:hover { background-color: #113D76; color: #fff; }
        .button.is-danger-light { background: #fff; color: #dc2626; border: 1px solid #dc2626; }
        .button.is-danger-light:hover { background: #dc2626; color: #fff; }
        .msg-error { background: #fef2f2; color: #b91c1c; padding: 10px 14px; border-radius: 8px; font-size: 0.85rem; margin-bottom: 12px; }
        .msg-success { background: #ecfdf5; color: #047857; padding: 10px 14px; border-radius: 8px; font-size: 0.85rem; margin-bottom: 12px; }
        .table { font-size: 0.82rem; }
        .table th { font-weight: 600; color: #555; }
        .kw-badge { display: inline-block; background: #113D76; color: #fff; padding: 3px 10px; border-radius: 6px; font-size: 0.75rem; font-weight: 600; margin: 1px 2px; font-family: monospace; }
        .badge { display: inline-block; padding: 2px 10px; border-radius: 100px; font-size: 0.7rem; font-weight: 600; }
        .badge-ok { background: #ecfdf5; color: #059669; }
        .badge-fallback { background: #fffbeb; color: #92400e; }
        .badge-manual { background: #eff6ff; color: #1d4ed8; }
        .badge-on { background: #ecfdf5; color: #059669; }
        .badge-off { background: #f3f4f6; color: #9ca3af; }
        .stats-row { display: flex; gap: 12px; margin-bottom: 20px; flex-wrap: wrap; }
        .stat-box { background: #fff; border-radius: 10px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); padding: 16px 20px; flex: 1; min-width: 140px; text-align: center; }
        .stat-box .num { font-size: 1.5rem; font-weight: 700; color: #113D76; }
        .stat-box .lbl { font-size: 0.7rem; color: #999; text-transform: uppercase; letter-spacing: 0.05em; margin-top: 4px; }
        .empty-state { text-align: center; padding: 24px; color: #bbb; font-size: 0.85rem; }
    </style>
</head>
<body>
    <div class="nav-bar">
        <div class="nav-logo">
            <img src="~/dasc.svg" alt="DASC">
            <h1>Painel Administrativo</h1>
        </div>
        <div class="nav-links">
            <a href="/Admin/Volunteers">Voluntários</a>
            <a href="/Admin/CertificateConfig">Certificados</a>
            <a href="/Admin/Logout" class="nav-logout">Sair</a>
        </div>
    </div>

    <div class="container-area">
        <div class="stats-row">
            <div class="stat-box"><div class="num" id="statTotal">-</div><div class="lbl">Check-ins</div></div>
            <div class="stat-box"><div class="num" id="statToday">-</div><div class="lbl">Hoje</div></div>
            <div class="stat-box"><div class="num" id="statFallback">-</div><div class="lbl">Fallback</div></div>
        </div>

        <!-- TIME SLOTS -->
        <div class="panel-card">
            <h2>Horários (Time Slots)</h2>
            <div id="tsMsg"></div>
            <table class="table is-fullwidth is-hoverable is-striped">
                <thead><tr><th>ID</th><th>Início</th><th>Fim</th><th>Turno</th><th>Horas AACC</th><th>Palestras</th><th></th></tr></thead>
                <tbody>
                    @foreach (var ts in timeSlots)
                    {
                        var lecCount = lectures.Count(l => l.TimeSlotId == ts.Id);
                        <tr>
                            <td>@ts.Id</td>
                            <td>@ts.StartTime.ToString("dd/MM HH:mm")</td>
                            <td>@ts.EndTime.ToString("dd/MM HH:mm")</td>
                            <td><span class="badge badge-ok">@ts.Shift</span></td>
                            <td><input class="input is-small" type="number" id="tsHours_@ts.Id" value="@ts.CreditHours" min="1" max="20" style="width:60px;display:inline-block;" onchange="updateCreditHours(@ts.Id, this.value)"></td>
                            <td>@lecCount palestra(s)</td>
                            <td><button class="button is-danger-light is-small" onclick="deleteTimeSlot(@ts.Id)">Remover</button></td>
                        </tr>
                    }
                </tbody>
            </table>
            <div class="columns" style="margin-top:12px;">
                <div class="column is-3"><div class="field"><div class="control"><input class="input" type="datetime-local" id="tsStart"></div></div></div>
                <div class="column is-3"><div class="field"><div class="control"><input class="input" type="datetime-local" id="tsEnd"></div></div></div>
                <div class="column is-2">
                    <div class="field"><div class="control"><div class="select is-fullwidth">
                        <select id="tsShift">
                            <option value="Matutino">Matutino</option>
                            <option value="Vespertino">Vespertino</option>
                            <option value="Noturno">Noturno</option>
                            <option value="Integral">Integral</option>
                        </select>
                    </div></div></div>
                </div>
                <div class="column is-2"><div class="field"><label class="label is-small">Horas AACC</label><div class="control"><input class="input" type="number" id="tsCreditHours" value="2" min="1" max="10"></div></div></div>
                <div class="column is-2" style="display:flex;align-items:flex-end;"><button class="button is-brand is-fullwidth" onclick="createTimeSlot()">Criar</button></div>
            </div>
        </div>

        <!-- LECTURES -->
        <div class="panel-card">
            <h2>Palestras</h2>
            <div id="lecMsg"></div>
            <table class="table is-fullwidth is-hoverable is-striped">
                <thead><tr><th>Título</th><th>Palestrante</th><th>Horário</th><th>Turno</th><th>Palavras-chave</th><th>Inscrições</th><th>Inscritos</th><th></th></tr></thead>
                <tbody>
                    @foreach (var l in lectures)
                    {
                        var count = preRegCounts.ContainsKey(l.Id) ? preRegCounts[l.Id] : 0;
                        <tr>
                            <td><strong>@l.Title</strong></td>
                            <td>@l.Speaker</td>
                            <td>@l.TimeSlot.StartTime.ToString("dd/MM HH:mm") - @l.TimeSlot.EndTime.ToString("HH:mm")</td>
                            <td><span class="badge badge-ok">@l.TimeSlot.Shift</span></td>
                            <td>
                                <span class="kw-badge">@l.Keyword1</span>
                                <span class="kw-badge">@l.Keyword2</span>
                                <span class="kw-badge">@l.Keyword3</span>
                            </td>
                            <td>
                                <button class="button is-small @(l.IsPreRegistrationEnabled ? "is-brand" : "is-outlined-brand")" style="font-size:0.7rem;padding:2px 10px;" onclick="togglePreReg(@l.Id)">
                                    @(l.IsPreRegistrationEnabled ? "Abertas" : "Fechadas")
                                </button>
                            </td>
                            <td>
                                @if (count > 0)
                                {
                                    <a href="/Admin/PreRegistrations?lectureId=@l.Id" style="font-weight:600;color:#113D76;">@count inscrito(s)</a>
                                }
                                else
                                {
                                    <span style="color:#bbb;">0</span>
                                }
                            </td>
                            <td><button class="button is-danger-light is-small" onclick="deleteLecture(@l.Id)">Remover</button></td>
                        </tr>
                    }
                </tbody>
            </table>
            <hr>
            <p class="has-text-weight-semibold is-size-7 has-text-grey" style="margin-bottom:8px;">Nova palestra</p>
            <div class="columns">
                <div class="column is-3"><div class="field"><div class="control"><input class="input" type="text" id="lecTitle" placeholder="Título"></div></div></div>
                <div class="column is-2"><div class="field"><div class="control"><input class="input" type="text" id="lecSpeaker" placeholder="Palestrante"></div></div></div>
                <div class="column is-5">
                    <div class="field"><div class="control"><div class="select is-fullwidth">
                        <select id="lecTimeSlot">
                            @foreach (var ts in timeSlots)
                            {
                                <option value="@ts.Id">@ts.StartTime.ToString("dd/MM HH:mm") - @ts.EndTime.ToString("HH:mm") (@ts.Shift)</option>
                            }
                        </select>
                    </div></div></div>
                </div>
                <div class="column is-2" style="display:flex;align-items:flex-end;"><button class="button is-brand is-fullwidth" onclick="createLecture()">Criar</button></div>
            </div>
        </div>

        <!-- MANUAL CHECK-IN -->
        <div class="panel-card">
            <h2>Check-in Manual</h2>
            <div id="manualMsg"></div>
            <div class="columns">
                <div class="column is-3"><div class="field"><label class="label is-small">E-mail</label><div class="control"><input class="input" type="email" id="mEmail" placeholder="aluno@furb.br"></div></div></div>
                <div class="column is-3"><div class="field"><label class="label is-small">Nome completo</label><div class="control"><input class="input" type="text" id="mName" placeholder="João da Silva"></div></div></div>
                <div class="column is-2"><div class="field"><label class="label is-small">Curso</label><div class="control"><div class="select is-fullwidth"><select id="mCourse"><option value="">-</option><option>Ciência da Computação</option><option>Ciência de Dados</option><option>Sistemas de Informação</option></select></div></div></div></div>
                <div class="column is-1"><div class="field"><label class="label is-small">Turno</label><div class="control"><div class="select is-fullwidth"><select id="mShift"><option value="">-</option><option>Matutino</option><option>Noturno</option></select></div></div></div></div>
                <div class="column is-1"><div class="field"><label class="label is-small">Fase</label><div class="control"><input class="input" type="number" id="mPhase" min="1" max="9" placeholder="1"></div></div></div>
                <div class="column is-2" style="display:flex;align-items:flex-end;">
                    <div class="field" style="width:100%;">
                        <label class="label is-small">Palestra</label>
                        <div class="control"><div class="select is-fullwidth"><select id="mLecture">
                            @foreach (var l in lectures)
                            {
                                <option value="@l.Id">@l.Title</option>
                            }
                        </select></div></div>
                    </div>
                </div>
            </div>
            <button class="button is-brand" onclick="manualCheckIn()">Registrar check-in manual</button>
        </div>

        <!-- CHECK-IN RECORDS -->
        <div class="panel-card">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
                <h2 style="margin:0;">Registros</h2>
                <div style="display:flex;gap:8px;align-items:center;">
                    <div class="select is-small">
                        <select id="filterLecture" onchange="loadCheckIns()">
                            <option value="">Todas as palestras</option>
                            @foreach (var l in lectures)
                            {
                                <option value="@l.Id">@l.Title</option>
                            }
                        </select>
                    </div>
                    <button class="button is-brand is-small" onclick="loadCheckIns()">Atualizar</button>
                </div>
            </div>
            <div id="checkinsTable"><div class="empty-state">Carregando...</div></div>
        </div>

        <!-- CERTIFICATES -->
        <div class="panel-card">
            <h2>Certificados</h2>
            <div style="display:flex;gap:12px;">
                <a href="/Admin/CertificateConfig" class="button is-brand">Configurar mensagem</a>
                <a href="/Admin/IssuedCertificates" class="button is-brand">Ver emissões</a>
            </div>
        </div>

        <div style="text-align:center;margin-top:16px;">
            <a href="/" style="font-size:0.8rem;color:#aaa;">&#8592; Voltar ao site</a>
        </div>
    </div>

    <script>
        function showMsg(id, t, type) { document.getElementById(id).innerHTML = `<div class="msg-${type}">${t}</div>`; }
        function esc(s) { const d = document.createElement('div'); d.textContent = s || ''; return d.innerHTML; }

        async function updateCreditHours(id, val) {
            const creditHours = parseInt(val) || 2;
            await fetch('/Admin/UpdateTimeSlotCreditHours', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ timeSlotId: id, creditHours }) });
        }

        async function createTimeSlot() {
            const start = document.getElementById('tsStart').value;
            const end = document.getElementById('tsEnd').value;
            const shift = document.getElementById('tsShift').value;
            const creditHours = parseInt(document.getElementById('tsCreditHours').value) || 2;
            if (!start || !end) { showMsg('tsMsg', 'Preencha início e fim.', 'error'); return; }
            const res = await fetch('/Admin/CreateTimeSlot', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ startTime: start, endTime: end, shift, creditHours }) });
            const data = await res.json();
            if (data.success) location.reload();
            else showMsg('tsMsg', data.message || 'Erro.', 'error');
        }

        async function deleteTimeSlot(id) {
            if (!confirm('Remover este horário e todas as palestras vinculadas?')) return;
            await fetch('/Admin/DeleteTimeSlot', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ timeSlotId: id }) });
            location.reload();
        }

        async function createLecture() {
            const title = document.getElementById('lecTitle').value.trim();
            const speaker = document.getElementById('lecSpeaker').value.trim();
            const tsId = parseInt(document.getElementById('lecTimeSlot').value);
            if (!title || !speaker) { showMsg('lecMsg', 'Preencha título e palestrante.', 'error'); return; }
            const res = await fetch('/Admin/CreateLecture', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ title, speaker, timeSlotId: tsId }) });
            const data = await res.json();
            if (data.success) location.reload();
            else showMsg('lecMsg', data.message || 'Erro.', 'error');
        }

        async function deleteLecture(id) {
            if (!confirm('Remover esta palestra?')) return;
            await fetch('/Admin/DeleteLecture', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ lectureId: id }) });
            location.reload();
        }

        async function togglePreReg(id) {
            await fetch('/Admin/TogglePreRegistration', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ lectureId: id }) });
            location.reload();
        }

        async function manualCheckIn() {
            const email = document.getElementById('mEmail').value.trim();
            const fullName = document.getElementById('mName').value.trim();
            const course = document.getElementById('mCourse').value;
            const shift = document.getElementById('mShift').value;
            const phase = parseInt(document.getElementById('mPhase').value) || 0;
            const lectureId = parseInt(document.getElementById('mLecture').value);
            if (!email || !fullName) { showMsg('manualMsg', 'Preencha e-mail e nome.', 'error'); return; }
            const res = await fetch('/Admin/ManualCheckIn', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email, fullName, course, shift, phase, lectureId }) });
            const data = await res.json();
            if (data.success) { showMsg('manualMsg', data.message, 'success'); document.getElementById('mEmail').value = ''; document.getElementById('mName').value = ''; loadCheckIns(); }
            else showMsg('manualMsg', data.message, 'error');
        }

        async function loadCheckIns() {
            const lectureId = document.getElementById('filterLecture').value;
            const url = '/Admin/GetCheckIns' + (lectureId ? `?lectureId=${lectureId}` : '');
            const res = await fetch(url);
            const data = await res.json();
            if (!data.success || !data.entries || data.entries.length === 0) {
                document.getElementById('checkinsTable').innerHTML = '<div class="empty-state">Nenhum registro encontrado.</div>';
                document.getElementById('statTotal').textContent = '0';
                document.getElementById('statToday').textContent = '0';
                document.getElementById('statFallback').textContent = '0';
                return;
            }
            const entries = data.entries;
            document.getElementById('statTotal').textContent = entries.length;
            const today = new Date().toISOString().slice(0, 10);
            document.getElementById('statToday').textContent = entries.filter(e => e.verifiedAt && e.verifiedAt.startsWith(today)).length;
            document.getElementById('statFallback').textContent = entries.filter(e => e.sesFallback).length;

            let html = `<table class="table is-fullwidth is-hoverable is-striped"><thead><tr>
                <th>Nome</th><th>E-mail</th><th>Curso</th><th>Turno</th><th>Fase</th><th>Palestra</th><th>Palestrante</th><th>Status</th><th>Verificado em</th>
            </tr></thead><tbody>`;

            for (const e of entries) {
                const badge = e.status === 'Manual' ? '<span class="badge badge-manual">Manual</span>'
                    : (e.sesFallback ? '<span class="badge badge-fallback">Fallback</span>' : '<span class="badge badge-ok">Verificado</span>');
                const dt = e.verifiedAt ? new Date(e.verifiedAt).toLocaleString('pt-BR') : '-';
                html += `<tr>
                    <td><strong>${esc(e.fullName)}</strong></td><td>${esc(e.email)}</td><td>${esc(e.course)}</td><td>${esc(e.shift)}</td><td>${e.phase || '-'}</td>
                    <td>${esc(e.lectureTitle)}</td><td>${esc(e.speaker)}</td><td>${badge}</td><td>${dt}</td>
                </tr>`;
            }
            html += '</tbody></table>';
            document.getElementById('checkinsTable').innerHTML = html;
        }

        loadCheckIns();
    </script>
</body>
</html>
