@{
    ViewData["Title"] = "Painel do Administrador";
    Layout = null;
    var sessions = ViewBag.Sessions as List<Sasc26.Models.Session> ?? new();
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SASC 26</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@1.0.4/css/bulma.min.css" />
    <link rel="stylesheet" href="~/css/bulmaswatch.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background: #f5f5f5; min-height: 100vh; }
        .nav-bar { background: #113D76; padding: 12px 20px; display: flex; align-items: center; justify-content: space-between; }
        .nav-bar h1 { font-size: 0.95rem; font-weight: 700; color: #fff; margin: 0; }
        .nav-bar a { font-size: 0.8rem; color: rgba(255,255,255,0.6); }
        .nav-bar a:hover { color: #fff; }
        .container-area { max-width: 1100px; margin: 0 auto; padding: 24px 16px; }
        .panel-card { background: #fff; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); padding: 24px; margin-bottom: 20px; }
        .panel-card h2 { font-size: 0.95rem; font-weight: 700; color: #1a1a1a; margin: 0 0 16px; }
        .input:focus, .select select:focus { border-color: #2EBDEF; box-shadow: 0 0 0 3px rgba(46,189,239,0.15); }
        .button.is-brand { background-color: #113D76; color: #fff; }
        .button.is-brand:hover { background-color: #0d2d5a; color: #fff; }
        .button.is-brand.is-light { background-color: #fff; color: #113D76; border: 1px solid #113D76; }
        .button.is-brand.is-light:hover { background-color: #113D76; color: #fff; }
        .msg-error { background: #fef2f2; color: #b91c1c; padding: 10px 14px; border-radius: 8px; font-size: 0.85rem; margin-bottom: 12px; }
        .msg-success { background: #ecfdf5; color: #047857; padding: 10px 14px; border-radius: 8px; font-size: 0.85rem; margin-bottom: 12px; }
        .table { font-size: 0.82rem; }
        .table th { font-weight: 600; color: #555; }
        .badge { display: inline-block; padding: 2px 10px; border-radius: 100px; font-size: 0.7rem; font-weight: 600; }
        .badge-ok { background: #ecfdf5; color: #059669; }
        .badge-fallback { background: #fffbeb; color: #92400e; }
        .badge-manual { background: #eff6ff; color: #1d4ed8; }
        .stats-row { display: flex; gap: 12px; margin-bottom: 20px; flex-wrap: wrap; }
        .stat-box { background: #fff; border-radius: 10px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); padding: 16px 20px; flex: 1; min-width: 140px; text-align: center; }
        .stat-box .num { font-size: 1.5rem; font-weight: 700; color: #113D76; }
        .stat-box .lbl { font-size: 0.7rem; color: #999; text-transform: uppercase; letter-spacing: 0.05em; margin-top: 4px; }
        .empty-state { text-align: center; padding: 32px; color: #bbb; font-size: 0.85rem; }
    </style>
</head>
<body>
    <div class="nav-bar">
        <h1>SASC 26 - Painel Administrativo</h1>
        <a href="/Admin/Logout">Sair</a>
    </div>

    <div class="container-area">
        <div class="stats-row" id="statsRow">
            <div class="stat-box"><div class="num" id="statTotal">-</div><div class="lbl">Check-ins</div></div>
            <div class="stat-box"><div class="num" id="statToday">-</div><div class="lbl">Hoje</div></div>
            <div class="stat-box"><div class="num" id="statFallback">-</div><div class="lbl">Fallback</div></div>
        </div>

        <div class="panel-card">
            <h2>Check-in Manual</h2>
            <div id="manualMsg"></div>
            <div class="columns">
                <div class="column is-4">
                    <div class="field">
                        <label class="label is-small">E-mail</label>
                        <div class="control">
                            <input class="input" type="email" id="mEmail" placeholder="aluno@furb.br">
                        </div>
                    </div>
                </div>
                <div class="column is-3">
                    <div class="field">
                        <label class="label is-small">Nome completo</label>
                        <div class="control">
                            <input class="input" type="text" id="mName" placeholder="João da Silva">
                        </div>
                    </div>
                </div>
                <div class="column is-2">
                    <div class="field">
                        <label class="label is-small">Curso</label>
                        <div class="control">
                            <div class="select is-fullwidth">
                                <select id="mCourse">
                                    <option value="">-</option>
                                    <option>Ciência da Computação</option>
                                    <option>Ciência de Dados</option>
                                    <option>Sistemas de Informação</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="column is-1">
                    <div class="field">
                        <label class="label is-small">Turno</label>
                        <div class="control">
                            <div class="select is-fullwidth">
                                <select id="mShift">
                                    <option value="">-</option>
                                    <option>Matutino</option>
                                    <option>Noturno</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="column is-1">
                    <div class="field">
                        <label class="label is-small">Fase</label>
                        <div class="control">
                            <input class="input" type="number" id="mPhase" min="1" max="9" placeholder="1">
                        </div>
                    </div>
                </div>
                <div class="column is-1" style="display:flex;align-items:flex-end;">
                    <div class="field">
                        <div class="control">
                            <button class="button is-brand is-fullwidth" onclick="manualCheckIn()">Add</button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="field">
                <div class="control">
                    <div class="select">
                        <select id="mSession">
                            @foreach (var s in sessions)
                            {
                                <option value="@s.Id">@s.Name</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <div class="panel-card">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
                <h2 style="margin:0;">Registros</h2>
                <div style="display:flex;gap:8px;align-items:center;">
                    <div class="select is-small">
                        <select id="filterSession" onchange="loadCheckIns()">
                            <option value="">Todas as sessões</option>
                            @foreach (var s in sessions)
                            {
                                <option value="@s.Id">@s.Name</option>
                            }
                        </select>
                    </div>
                    <button class="button is-brand is-light is-small" onclick="loadCheckIns()">Atualizar</button>
                </div>
            </div>
            <div id="checkinsTable">
                <div class="empty-state">Carregando...</div>
            </div>
        </div>

        <div class="panel-card">
            <h2>Certificados</h2>
            <button class="button is-brand" disabled title="Em breve">
                Emitir certificado
            </button>
        </div>

        <div style="text-align:center;margin-top:16px;">
            <a href="/" style="font-size:0.8rem;color:#aaa;">&#8592; Voltar ao site</a>
        </div>
    </div>

    <script>
        function showManualMsg(t, type) { document.getElementById('manualMsg').innerHTML = `<div class="msg-${type}">${t}</div>`; }

        async function manualCheckIn() {
            const email = document.getElementById('mEmail').value.trim();
            const fullName = document.getElementById('mName').value.trim();
            const course = document.getElementById('mCourse').value;
            const shift = document.getElementById('mShift').value;
            const phase = parseInt(document.getElementById('mPhase').value) || 0;
            const sessionId = parseInt(document.getElementById('mSession').value);

            if (!email || !fullName) { showManualMsg('Preencha e-mail e nome.', 'error'); return; }

            const res = await fetch('/Admin/ManualCheckIn', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email, fullName, course, shift, phase, sessionId })
            });
            const data = await res.json();
            if (data.success) {
                showManualMsg(data.message, 'success');
                document.getElementById('mEmail').value = '';
                document.getElementById('mName').value = '';
                loadCheckIns();
            } else {
                showManualMsg(data.message, 'error');
            }
        }

        async function loadCheckIns() {
            const sessionId = document.getElementById('filterSession').value;
            const url = '/Admin/GetCheckIns' + (sessionId ? `?sessionId=${sessionId}` : '');
            const res = await fetch(url);
            const data = await res.json();

            if (!data.success || !data.entries || data.entries.length === 0) {
                document.getElementById('checkinsTable').innerHTML = '<div class="empty-state">Nenhum registro encontrado.</div>';
                document.getElementById('statTotal').textContent = '0';
                document.getElementById('statToday').textContent = '0';
                document.getElementById('statFallback').textContent = '0';
                return;
            }

            const entries = data.entries;
            document.getElementById('statTotal').textContent = entries.length;

            const today = new Date().toISOString().slice(0, 10);
            const todayCount = entries.filter(e => e.verifiedAt && e.verifiedAt.startsWith(today)).length;
            document.getElementById('statToday').textContent = todayCount;

            const fallbackCount = entries.filter(e => e.sesFallback).length;
            document.getElementById('statFallback').textContent = fallbackCount;

            let html = `<table class="table is-fullwidth is-hoverable is-striped">
                <thead><tr>
                    <th>Nome</th><th>E-mail</th><th>Curso</th><th>Turno</th><th>Fase</th><th>Sessão</th><th>Status</th><th>Verificado em</th>
                </tr></thead><tbody>`;

            for (const e of entries) {
                const badge = e.verifiedAt
                    ? (e.sesFallback ? '<span class="badge badge-fallback">Fallback</span>'
                       : (e.status === 'Manual' ? '<span class="badge badge-manual">Manual</span>'
                       : '<span class="badge badge-ok">Verificado</span>'))
                    : '<span class="badge">Pendente</span>';
                const dt = e.verifiedAt ? new Date(e.verifiedAt).toLocaleString('pt-BR') : '-';
                html += `<tr>
                    <td><strong>${esc(e.fullName)}</strong></td>
                    <td>${esc(e.email)}</td>
                    <td>${esc(e.course)}</td>
                    <td>${esc(e.shift)}</td>
                    <td>${e.phase || '-'}</td>
                    <td>${esc(e.sessionName)}</td>
                    <td>${badge}</td>
                    <td>${dt}</td>
                </tr>`;
            }

            html += '</tbody></table>';
            document.getElementById('checkinsTable').innerHTML = html;
        }

        function esc(s) { const d = document.createElement('div'); d.textContent = s || ''; return d.innerHTML; }

        loadCheckIns();
    </script>
</body>
</html>
