@{
    ViewData["Title"] = "Voluntários";
    Layout = null;
    var ev = ViewBag.Event as Sasc26.Models.Event;
    var primaryColor = ev?.PrimaryColor ?? "#113D76";
    var accentColor = ev?.AccentColor ?? "#2EBDEF";
    var backgroundColor = ev?.BackgroundColor ?? "#f5f5f5";
    var eventName = ev?.Name ?? "SASC 26";
    var eventSlug = ev?.Slug ?? "";
    var volunteers = ViewBag.Volunteers as List<Sasc26.Models.VolunteerDetailDto> ?? new();
    var timeSlots = ViewBag.TimeSlots as List<Sasc26.Models.TimeSlot> ?? new();
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SASC 26</title>
    <link rel="stylesheet" href="~/css/bulmaswatch.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background: @backgroundColor; min-height: 100vh; }
        .nav-bar { background: @primaryColor; padding: 16px 24px; display: flex; align-items: center; gap: 16px; }
        .nav-logo { display: flex; align-items: center; gap: 12px; flex: 1; }
        .nav-logo img { height: 32px; }
        .nav-logo h1 { font-size: 1rem; font-weight: 700; color: #fff; margin: 0; }
        .nav-links { display: flex; gap: 16px; align-items: center; }
        .nav-links a { font-size: 0.8rem; color: @accentColor; }
        .nav-links a:hover { color: #fff; }
        .nav-links a.nav-logout { color: rgba(255,255,255,0.6); }
        .nav-links a.nav-logout:hover { color: #fff; }
        .container-area { max-width: 1200px; margin: 0 auto; padding: 24px 16px; }
        .panel-card { background: #fff; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); padding: 24px; margin-bottom: 20px; }
        .panel-card h2 { font-size: 0.95rem; font-weight: 700; color: #1a1a1a; margin: 0 0 16px; }
        .input:focus, .select select:focus { border-color: @accentColor; box-shadow: 0 0 0 3px rgba(46,189,239,0.15); }
        .button.is-brand { background-color: #fff; color: @primaryColor; }
        .button.is-brand:hover { background-color: #f0f0f0; color: @primaryColor; }
        .button.is-outlined-brand { background-color: transparent; color: @primaryColor; border: 1px solid @primaryColor; }
        .button.is-outlined-brand:hover { background-color: @primaryColor; color: #fff; }
        .button.is-danger-light { background: #fff; color: #dc2626; border: 1px solid #dc2626; }
        .button.is-danger-light:hover { background: #dc2626; color: #fff; }
        .table { font-size: 0.82rem; }
        .table th { font-weight: 600; color: #555; }
        .badge { display: inline-block; padding: 2px 10px; border-radius: 100px; font-size: 0.7rem; font-weight: 600; }
        .badge-ok { background: #ecfdf5; color: #059669; }
        .badge-pending { background: #fffbeb; color: #92400e; }
        .empty-state { text-align: center; padding: 24px; color: #bbb; font-size: 0.85rem; }
        .volunteer-row { cursor: pointer; }
        .volunteer-row:hover { background: #f8faff; }
        .detail-overlay { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 100; align-items: center; justify-content: center; }
        .detail-overlay.active { display: flex; }
        .detail-card { background: #fff; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.15); padding: 24px; max-width: 600px; width: 90%; max-height: 80vh; overflow-y: auto; }
        .detail-card h3 { font-size: 1rem; font-weight: 700; color: #1a1a1a; margin: 0 0 8px; }
        .detail-card .sub { font-size: 0.8rem; color: #888; margin-bottom: 16px; }
        .slot-row { display: flex; align-items: center; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid #f0f0f0; }
        .slot-row:last-child { border-bottom: none; }
        .slot-label { font-size: 0.85rem; color: #1a1a1a; }
        .slot-shift { font-size: 0.7rem; color: #888; }
        .toggle-check { display: flex; align-items: center; gap: 8px; }
        .msg-success { background: #ecfdf5; color: #047857; padding: 10px 14px; border-radius: 8px; font-size: 0.85rem; margin-bottom: 12px; }
        .msg-error { background: #fef2f2; color: #b91c1c; padding: 10px 14px; border-radius: 8px; font-size: 0.85rem; margin-bottom: 12px; }
        .stats-row { display: flex; gap: 12px; margin-bottom: 20px; flex-wrap: wrap; }
        .stat-box { background: #fff; border-radius: 10px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); padding: 16px 20px; flex: 1; min-width: 140px; text-align: center; }
        .stat-box .num { font-size: 1.5rem; font-weight: 700; color: @primaryColor; }
        .stat-box .lbl { font-size: 0.7rem; color: #999; text-transform: uppercase; letter-spacing: 0.05em; margin-top: 4px; }
        .close-btn { position: absolute; top: 12px; right: 16px; background: none; border: none; font-size: 1.2rem; cursor: pointer; color: #888; }
        .detail-card { position: relative; }
    </style>
</head>
<body>
    <div class="nav-bar">
        <div class="nav-logo">
            <img src="~/dasc.svg" alt="DASC">
            <h1>Voluntários</h1>
        </div>
        <div class="nav-links">
            <a href="/@eventSlug/Admin/Dashboard">&#8592; Dashboard</a>
            <a href="/@eventSlug/Admin/Logout" class="nav-logout">Sair</a>
        </div>
    </div>

    <div class="container-area">
        <div class="stats-row">
            <div class="stat-box"><div class="num" id="statTotal">@volunteers.Count</div><div class="lbl">Voluntários</div></div>
            <div class="stat-box"><div class="num" id="statCheckIns">@volunteers.SelectMany(v => v.CheckIns).Count()</div><div class="lbl">Check-ins</div></div>
        </div>

        <div class="panel-card">
            <h2>Voluntários Cadastrados</h2>
            <div id="volunteerMsg"></div>
            @if (volunteers.Count == 0)
            {
                <div class="empty-state">Nenhum voluntário cadastrado ainda.</div>
            }
            else
            {
                <table class="table is-fullwidth is-hoverable is-striped">
                    <thead><tr><th>Nome</th><th>E-mail</th><th>Curso</th><th>Turno</th><th>Fase</th><th>Check-ins</th><th></th></tr></thead>
                    <tbody>
                        @foreach (var v in volunteers)
                        {
                            <tr class="volunteer-row" onclick="openDetail('@v.Id')">
                                <td><strong>@v.Name</strong></td>
                                <td>@v.Email</td>
                                <td>@v.Course</td>
                                <td>@v.Shift</td>
                                <td>@v.Semester</td>
                                <td><span class="badge badge-ok">@v.CheckIns.Count</span></td>
                                <td><button class="button is-outlined-brand is-small" onclick="event.stopPropagation(); openDetail('@v.Id')">Gerenciar</button></td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

    <!-- Detail Overlay -->
    <div class="detail-overlay" id="detailOverlay" onclick="closeDetail(event)">
        <div class="detail-card" onclick="event.stopPropagation()">
            <button class="close-btn" onclick="closeDetail()">&times;</button>
            <div id="detailContent"></div>
        </div>
    </div>

    <script>
        const baseUrl = '/@eventSlug';
        const timeSlots = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(timeSlots.Select(ts => new { ts.Id, Label = $"{ts.StartTime:dd/MM HH:mm} - {ts.EndTime:HH:mm}", ts.Shift }), new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }));

        function esc(s) { const d = document.createElement('div'); d.textContent = s || ''; return d.innerHTML; }

        function showMsg(t, type) { document.getElementById('volunteerMsg').innerHTML = `<div class="msg-${type}">${t}</div>`; }

        async function openDetail(id) {
            const res = await fetch(baseUrl + `/Admin/GetVolunteerDetail?id=${id}`);
            const data = await res.json();
            if (!data.success) { alert('Erro ao carregar voluntário.'); return; }
            const v = data.volunteer;
            const checkedSlotIds = new Set(v.checkIns.map(c => c.timeSlotId));

            let slotsHtml = '';
            for (const ts of timeSlots) {
                const checked = checkedSlotIds.has(ts.id);
                const checkInEntry = v.checkIns.find(c => c.timeSlotId === ts.id);
                let actionHtml = '';
                if (checked) {
                    actionHtml = `<button class="button is-danger-light is-small" onclick="removeCheckIn('${checkInEntry.id}', '${v.id}')">Remover</button>`;
                } else {
                    actionHtml = `<button class="button is-outlined-brand is-small" onclick="addCheckIn('${v.id}', ${ts.id})">Adicionar</button>`;
                }
                const badge = checked ? '<span class="badge badge-ok">Presente</span>' : '<span class="badge badge-pending">Ausente</span>';
                slotsHtml += `<div class="slot-row">
                    <div>
                        <div class="slot-label">${esc(ts.label)}</div>
                        <div class="slot-shift">${esc(ts.shift)}</div>
                    </div>
                    <div class="toggle-check">
                        ${badge}
                        ${actionHtml}
                    </div>
                </div>`;
            }

            const checkInsHtml = v.checkIns.length > 0
                ? v.checkIns.map(c => `<div style="font-size:0.8rem;color:#666;margin-top:2px;">${esc(c.timeSlotLabel)} - ${new Date(c.createdAt).toLocaleString('pt-BR')}</div>`).join('')
                : '<div style="font-size:0.8rem;color:#bbb;">Nenhuma presença registrada.</div>';

            document.getElementById('detailContent').innerHTML = `
                <h3>${esc(v.name)}</h3>
                <div class="sub">${esc(v.email)} &middot; ${esc(v.course)} &middot; ${esc(v.shift)} &middot; Fase ${v.semester}</div>
                <p style="font-size:0.7rem;font-weight:600;color:#bbb;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:8px;">Gestão de Presenças</p>
                ${slotsHtml}
            `;
            document.getElementById('detailOverlay').classList.add('active');
        }

        function closeDetail(e) {
            if (e && e.target && !e.target.classList.contains('detail-overlay')) return;
            document.getElementById('detailOverlay').classList.remove('active');
        }

        async function addCheckIn(volunteerId, timeSlotId) {
            const res = await fetch(baseUrl + '/Admin/AddVolunteerCheckIn', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ volunteerId, timeSlotId }) });
            const data = await res.json();
            if (data.success) { openDetail(volunteerId); refreshPage(); }
            else { alert(data.message || 'Erro ao adicionar check-in.'); }
        }

        async function removeCheckIn(checkInId, volunteerId) {
            if (!confirm('Remover este check-in?')) return;
            const res = await fetch(baseUrl + '/Admin/RemoveVolunteerCheckIn', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ checkInId }) });
            const data = await res.json();
            if (data.success) { openDetail(volunteerId); refreshPage(); }
            else { alert('Erro ao remover check-in.'); }
        }

        async function refreshPage() {
            const res = await fetch(baseUrl + '/Admin/GetVolunteers');
            const data = await res.json();
            if (data.success && data.volunteers) {
                document.getElementById('statTotal').textContent = data.volunteers.length;
                document.getElementById('statCheckIns').textContent = data.volunteers.reduce((sum, v) => sum + v.checkIns.length, 0);
            }
        }
    </script>
</body>
</html>