@model Sasc26.Models.Lecture
@{
    ViewData["Title"] = "Projeção - " + Model.Title;
    Layout = null;
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        html, body {
            width: 100%;
            height: 100%;
            overflow: hidden;
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #0a1628 0%, #113D76 50%, #0a1628 100%);
            color: #fff;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
        }
        .content {
            width: 100%;
            max-width: 1400px;
            padding: 60px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 48px;
        }
        .logo-area {
            position: absolute;
            top: 40px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            align-items: center;
            gap: 16px;
            opacity: 0.9;
        }
        .logo-area img { height: 48px; }
        .logo-area span {
            font-size: 1.4rem;
            font-weight: 700;
            color: #2EBDEF;
            letter-spacing: 0.05em;
        }
        .presentation-name {
            font-size: clamp(2.5rem, 5vw, 5rem);
            font-weight: 900;
            line-height: 1.1;
            color: #fff;
            text-shadow: 0 4px 30px rgba(0,0,0,0.3);
            max-width: 90%;
        }
        .speaker-name {
            font-size: clamp(1.2rem, 2.5vw, 2.2rem);
            font-weight: 600;
            color: #2EBDEF;
            margin-top: -24px;
        }
        .divider {
            width: 120px;
            height: 4px;
            background: linear-gradient(90deg, #2EBDEF, #113D76);
            border-radius: 2px;
        }
        .words-label {
            font-size: clamp(1rem, 1.8vw, 1.6rem);
            font-weight: 600;
            color: rgba(255,255,255,0.7);
            text-transform: uppercase;
            letter-spacing: 0.15em;
        }
        .words-container {
            display: flex;
            gap: 32px;
            flex-wrap: wrap;
            justify-content: center;
        }
        .word-box {
            background: rgba(255,255,255,0.08);
            border: 2px solid rgba(46,189,239,0.4);
            border-radius: 20px;
            padding: 32px 56px;
            backdrop-filter: blur(10px);
            box-shadow: 0 8px 40px rgba(0,0,0,0.2);
        }
        .word-box span {
            font-size: clamp(2.5rem, 6vw, 6rem);
            font-weight: 900;
            color: #fff;
            font-family: 'Courier New', Courier, monospace;
            letter-spacing: 0.05em;
        }
        .url-area {
            position: absolute;
            bottom: 50px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 12px;
        }
        .url-label {
            font-size: 1rem;
            font-weight: 600;
            color: rgba(255,255,255,0.5);
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }
        .url-value {
            font-size: clamp(1.5rem, 3vw, 3rem);
            font-weight: 700;
            color: #2EBDEF;
            letter-spacing: 0.03em;
        }
        .fullscreen-hint {
            position: absolute;
            top: 40px;
            right: 40px;
            font-size: 0.85rem;
            color: rgba(255,255,255,0.3);
            cursor: pointer;
            padding: 8px 16px;
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 8px;
            transition: all 0.2s;
        }
        .fullscreen-hint:hover {
            color: rgba(255,255,255,0.7);
            border-color: rgba(255,255,255,0.4);
            background: rgba(255,255,255,0.05);
        }
    </style>
</head>
<body>
    <div class="logo-area">
        <img src="~/dasc.svg" alt="DASC">
        <span>SASC 26</span>
    </div>

    <div class="fullscreen-hint" onclick="toggleFullscreen()" title="Alternar tela cheia">
        Tela Cheia (F11)
    </div>

    <div class="content">
        <div class="presentation-name">@Model.Title</div>
        <div class="speaker-name">@Model.Speaker</div>
        <div class="divider"></div>
        <div class="words-label">Palavras-chave</div>
        <div class="words-container">
            <div class="word-box"><span>@Model.Keyword1</span></div>
            <div class="word-box"><span>@Model.Keyword2</span></div>
            <div class="word-box"><span>@Model.Keyword3</span></div>
        </div>
    </div>

    <div class="url-area">
        <div class="url-label">Acesse</div>
        <div class="url-value">sasc26.windisch.com.br</div>
    </div>

    <script>
        function toggleFullscreen() {
            if (!document.fullscreenElement) {
                document.documentElement.requestFullscreen().catch(() => {});
            } else {
                document.exitFullscreen().catch(() => {});
            }
        }
        document.addEventListener('keydown', function(e) {
            if (e.key === 'f' || e.key === 'F') {
                toggleFullscreen();
            }
        });
    </script>
</body>
</html>
