@{
    Layout = null;
    var lecture = ViewBag.Lecture as Sasc26.Models.Lecture;
    var token = ViewBag.Token as string;
    var payload = ViewBag.Payload as string;
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Check-in Mágico - @lecture?.Title</title>
    <link rel="stylesheet" href="~/css/bulmaswatch.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background: #0a0a1a; min-height: 100vh; display: flex; align-items: center; justify-content: center; color: #fff; }
        .broadcast-card { background: #111128; border-radius: 16px; padding: 40px; max-width: 520px; width: 100%; margin: 0 16px; text-align: center; box-shadow: 0 0 40px rgba(46,189,239,0.15); }
        .broadcast-card h1 { font-size: 1.4rem; font-weight: 700; margin: 0 0 8px; }
        .broadcast-card .lecture-name { font-size: 1rem; color: #2EBDEF; margin-bottom: 24px; }
        .pulse-ring { display: inline-block; width: 80px; height: 80px; border-radius: 50%; background: rgba(46,189,239,0.15); position: relative; margin: 20px 0; }
        .pulse-ring::before, .pulse-ring::after { content: ''; position: absolute; inset: 0; border-radius: 50%; border: 3px solid #2EBDEF; animation: pulse-wave 2s ease-out infinite; }
        .pulse-ring::after { animation-delay: 1s; }
        .pulse-icon { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); font-size: 2rem; }
        @@keyframes pulse-wave { 0% { transform: scale(1); opacity: 1; } 100% { transform: scale(1.8); opacity: 0; } }
        .status-text { font-size: 1.1rem; font-weight: 600; color: #2EBDEF; margin: 8px 0 24px; }
        .token-debug { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; padding: 12px; margin: 16px 0 24px; font-family: monospace; font-size: 1rem; letter-spacing: 2px; color: #ccc; cursor: pointer; }
        .token-debug:hover { background: rgba(255,255,255,0.08); }
        .token-label { font-size: 0.75rem; color: #888; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px; }
        .btn-stop { background: #dc2626; color: #fff; border: none; padding: 12px 32px; border-radius: 8px; font-size: 0.9rem; font-weight: 600; cursor: pointer; }
        .btn-stop:hover { background: #b91c1c; }
        .btn-dashboard { background: transparent; color: #888; border: 1px solid #444; padding: 10px 24px; border-radius: 8px; font-size: 0.85rem; cursor: pointer; margin-top: 12px; display: inline-block; text-decoration: none; }
        .btn-dashboard:hover { color: #fff; border-color: #666; }
    </style>
</head>
<body>
    <div class="broadcast-card">
        <h1>🔊 Check-in Mágico</h1>
        <div class="lecture-name">@lecture?.Title</div>
        <div class="pulse-ring" id="pulseRing">
            <span class="pulse-icon">🔊</span>
        </div>
        <div class="status-text" id="statusText">Transmitindo...</div>
        <div class="token-label">Token para debug</div>
        <div class="token-debug" id="tokenDebug" title="Clique para copiar" onclick="copyToken()">@token</div>
        <div id="expiredMsg" style="display:none;margin-bottom:16px;color:#f87171;font-weight:600;"></div>
        <button class="btn-stop" id="btnStop" onclick="stopBroadcast()">Encerrar transmissão</button>
        <br>
        <a href="/@ViewBag.EventSlug/Admin/Dashboard" class="btn-dashboard">← Voltar ao Dashboard</a>
    </div>

    <script src="https://quiet.github.io/quiet-js/quiet.js"></script>
    <script src="https://quiet.github.io/quiet-js/quiet-profiles.js"></script>
    <script>
        var payload = "@payload";
        var transmitter = null;
        var running = true;

        Quiet.init({ profilesPrefix: "https://quiet.github.io/quiet-js/" });
        Quiet.addReadyCallback(function () {
            if (!running) return;
            transmitter = Quiet.transmitter({
                profile: "ultrasonic",
                onFinish: function () {
                    if (!running) return;
                    setTimeout(function () {
                        if (running) transmitter.transmit(Quiet.str2ab(payload));
                    }, 1000);
                }
            });
            transmitter.transmit(Quiet.str2ab(payload));
        });

        function stopBroadcast() {
            running = false;
            document.getElementById('pulseRing').style.animationPlayState = 'paused';
            document.getElementById('statusText').textContent = 'Transmissão encerrada';
            document.getElementById('btnStop').style.display = 'none';
            if (transmitter) {
                try { transmitter.cancel(); } catch (e) {}
            }
        }

        function copyToken() {
            navigator.clipboard.writeText("@token").then(function () {
                var el = document.getElementById("tokenDebug");
                el.textContent = "Copiado!";
                setTimeout(function () { el.textContent = "@token"; }, 1500);
            });
        }

        var createdAt = new Date("@DateTime.UtcNow.ToString("o")");
        var expiresAt = new Date(createdAt.getTime() + 10 * 60 * 1000);

        function checkExpiry() {
            if (!running) return;
            var now = new Date();
            if (now >= expiresAt) {
                document.getElementById('expiredMsg').textContent = 'Sessão expirada! Gere uma nova no Dashboard.';
                document.getElementById('expiredMsg').style.display = 'block';
                document.getElementById('statusText').textContent = 'Sessão expirada';
                stopBroadcast();
                return;
            }
            var remaining = Math.max(0, Math.floor((expiresAt - now) / 1000));
            var min = Math.floor(remaining / 60);
            var sec = remaining % 60;
            document.getElementById('statusText').textContent = 'Transmitindo... (' + min + ':' + (sec < 10 ? '0' : '') + sec + ')';
        }
        setInterval(checkExpiry, 1000);
        checkExpiry();
    </script>
</body>
</html>