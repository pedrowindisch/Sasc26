@{
    Layout = null;
    var requests = ViewBag.Requests as List<Sasc26.Services.RetroactiveRequestEntryDto> ?? new();
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Solicitações Retroativas - SASC 26</title>
    <link rel="stylesheet" href="~/css/bulmaswatch.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background: #f5f5f5; min-height: 100vh; }
        .nav-bar { background: #113D76; padding: 16px 24px; display: flex; align-items: center; gap: 16px; }
        .nav-logo { display: flex; align-items: center; gap: 12px; flex: 1; }
        .nav-logo img { height: 32px; }
        .nav-logo h1 { font-size: 1rem; font-weight: 700; color: #fff; margin: 0; }
        .nav-links { display: flex; gap: 16px; align-items: center; }
        .nav-links a { font-size: 0.8rem; color: #2EBDEF; }
        .nav-links a:hover { color: #fff; }
        .container-area { max-width: 1200px; margin: 0 auto; padding: 24px 16px; }
        .panel-card { background: #fff; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); padding: 24px; margin-bottom: 20px; }
        .panel-card h2 { font-size: 0.95rem; font-weight: 700; color: #1a1a1a; margin: 0 0 16px; }
        .msg-error { background: #fef2f2; color: #b91c1c; padding: 10px 14px; border-radius: 8px; font-size: 0.85rem; margin-bottom: 12px; }
        .msg-success { background: #ecfdf5; color: #047857; padding: 10px 14px; border-radius: 8px; font-size: 0.85rem; margin-bottom: 12px; }
        .button.is-brand { background-color: #fff; color: #113D76; }
        .button.is-brand:hover { background-color: #f0f0f0; color: #113D76; }
        .button.is-success-light { background: #fff; color: #059669; border: 1px solid #059669; }
        .button.is-success-light:hover { background: #059669; color: #fff; }
        .button.is-danger-light { background: #fff; color: #dc2626; border: 1px solid #dc2626; }
        .button.is-danger-light:hover { background: #dc2626; color: #fff; }
        .table { font-size: 0.82rem; }
        .table th { font-weight: 600; color: #555; }
        .badge { display: inline-block; padding: 2px 10px; border-radius: 100px; font-size: 0.7rem; font-weight: 600; }
        .badge-pending { background: #fffbeb; color: #92400e; }
        .empty-state { text-align: center; padding: 24px; color: #bbb; font-size: 0.85rem; }
    </style>
</head>
<body>
    <div class="nav-bar">
        <div class="nav-logo">
            <img src="~/dasc.svg" alt="DASC">
            <h1>Solicitações Retroativas</h1>
        </div>
        <div class="nav-links">
            <a href="/Admin/Dashboard">Painel</a>
            <a href="/Admin/Logout" style="color:rgba(255,255,255,0.6);">Sair</a>
        </div>
    </div>

    <div class="container-area">
        <div class="panel-card">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
                <h2 style="margin:0;">Solicitações Pendentes</h2>
                <button class="button is-brand is-small" onclick="loadRequests()">Atualizar</button>
            </div>
            <div id="requestsTable"></div>
        </div>

        <div style="text-align:center;margin-top:16px;">
            <a href="/Admin/Dashboard" style="font-size:0.8rem;color:#aaa;">&larr; Voltar ao painel</a>
        </div>
    </div>

    <script>
        function showMsg(t, type) { /* not needed here but kept for consistency */ }

        async function approveRequest(id) {
            if (!confirm('Aprovar esta solicitação e registrar a presença?')) return;
            const res = await fetch('/Admin/ApproveRetroactiveRequest', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ requestId: id }) });
            const data = await res.json();
            if (data.success) { alert(data.message); loadRequests(); }
            else alert(data.message || 'Erro ao aprovar.');
        }

        async function rejectRequest(id) {
            if (!confirm('Rejeitar esta solicitação?')) return;
            const res = await fetch('/Admin/RejectRetroactiveRequest', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ requestId: id }) });
            const data = await res.json();
            if (data.success) { alert(data.message); loadRequests(); }
            else alert(data.message || 'Erro ao rejeitar.');
        }

        function esc(s) { const d = document.createElement('div'); d.textContent = s || ''; return d.innerHTML; }

        async function loadRequests() {
            try {
                const res = await fetch('/Admin/GetPendingRetroactiveRequests');
                const data = await res.json();
                const container = document.getElementById('requestsTable');
                if (!data.success || !data.requests || data.requests.length === 0) {
                    container.innerHTML = '<div class="empty-state">Nenhuma solicitação pendente.</div>';
                    return;
                }
                const requests = data.requests;
                let html = `<table class="table is-fullwidth is-hoverable is-striped"><thead><tr>
                    <th>Nome</th><th>E-mail</th><th>Curso</th><th>Turno</th><th>Fase</th><th>Palestra</th><th>Palestrante</th><th>Horário</th><th>Justificativa</th><th>Solicitado em</th><th></th>
                </tr></thead><tbody>`;
                for (const r of requests) {
                    const dt = new Date(r.requestedAt).toLocaleString('pt-BR');
                    html += `<tr>
                        <td><strong>${esc(r.fullName)}</strong></td>
                        <td>${esc(r.email)}</td>
                        <td>${esc(r.course)}</td>
                        <td>${esc(r.shift)}</td>
                        <td>${r.phase || '-'}</td>
                        <td>${esc(r.lectureTitle)}</td>
                        <td>${esc(r.speaker)}</td>
                        <td>${esc(r.timeSlotLabel)}</td>
                        <td>${esc(r.justification) || '-'}</td>
                        <td>${dt}</td>
                        <td style="white-space:nowrap;">
                            <button class="button is-success-light is-small" onclick="approveRequest('${r.id}')" style="margin-right:4px;">Aprovar</button>
                            <button class="button is-danger-light is-small" onclick="rejectRequest('${r.id}')">Rejeitar</button>
                        </td>
                    </tr>`;
                }
                html += '</tbody></table>';
                container.innerHTML = html;
            } catch { document.getElementById('requestsTable').innerHTML = '<div class="empty-state">Erro ao carregar solicitações.</div>'; }
        }

        loadRequests();
    </script>
</body>
</html>