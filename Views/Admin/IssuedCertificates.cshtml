@{
    ViewData["Title"] = "Certificados Emitidos";
    Layout = null;
    var certificates = ViewBag.Certificates as List<Sasc26.Models.IssuedCertificateDto> ?? new();
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SASC 26</title>
    <link rel="stylesheet" href="~/css/bulmaswatch.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background: #f5f5f5; min-height: 100vh; }
        .nav-bar { background: #113D76; padding: 16px 24px; display: flex; align-items: center; gap: 16px; }
        .nav-logo { display: flex; align-items: center; gap: 12px; flex: 1; }
        .nav-logo img { height: 32px; }
        .nav-logo h1 { font-size: 1rem; font-weight: 700; color: #fff; margin: 0; }
        .nav-links { display: flex; gap: 16px; align-items: center; }
        .nav-links a { font-size: 0.8rem; color: #2EBDEF; }
        .nav-links a:hover { color: #fff; }
        .nav-links a.nav-logout { color: rgba(255,255,255,0.6); }
        .nav-links a.nav-logout:hover { color: #fff; }
        .container-area { max-width: 1000px; margin: 0 auto; padding: 24px 16px; }
        .panel-card { background: #fff; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); padding: 24px; margin-bottom: 20px; }
        .panel-card h2 { font-size: 0.95rem; font-weight: 700; color: #1a1a1a; margin: 0 0 16px; }
        .table { font-size: 0.82rem; }
        .table th { font-weight: 600; color: #555; }
        .badge { display: inline-block; padding: 2px 10px; border-radius: 100px; font-size: 0.7rem; font-weight: 600; background: #ecfdf5; color: #059669; }
        .empty-state { text-align: center; padding: 24px; color: #bbb; font-size: 0.85rem; }
        .button.is-brand { background-color: #fff; color: #113D76; }
        .button.is-brand:hover { background-color: #f0f0f0; color: #113D76; }
        .button.is-outlined-brand { background-color: transparent; color: #113D76; border: 1px solid #113D76; }
        .button.is-outlined-brand:hover { background-color: #113D76; color: #fff; }
        .export-progress { display: none; align-items: center; gap: 10px; font-size: 0.8rem; color: #555; }
        .export-progress .spinner { width: 16px; height: 16px; border: 2px solid #113D76; border-top-color: transparent; border-radius: 50%; animation: spin 0.8s linear infinite; }
        @@keyframes spin { to { transform: rotate(360deg); } }
        .export-progress .error-msg { color: #dc2626; }
    </style>
</head>
<body>
    <div class="nav-bar">
        <div class="nav-logo">
            <img src="~/dasc.svg" alt="DASC">
            <h1>Certificados Emitidos</h1>
        </div>
        <div class="nav-links">
            <a href="/Admin/Dashboard">&#8592; Dashboard</a>
            <a href="/Admin/Feedback">Avaliações</a>
            <a href="/Admin/CertificateConfig">Config. Certificado</a>
            <a href="/Admin/Logout" class="nav-logout">Sair</a>
        </div>
    </div>

    <div class="container-area">
        <div class="panel-card">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;flex-wrap:wrap;gap:8px;">
                <h2 style="margin:0;">Certificados Emitidos</h2>
                <div style="display:flex;align-items:center;gap:12px;">
                    @if (certificates.Count > 0)
                    {
                        <button id="exportBtn" class="button is-brand is-small" style="background:#113D76;color:#fff;font-size:0.8rem;border:none;cursor:pointer;" onclick="startExport()">
                            📦 Exportar todos (ZIP)
                        </button>
                    }
                    <div id="exportProgress" class="export-progress">
                        <div class="spinner"></div>
                        <span id="exportStatusText">Gerando certificados...</span>
                    </div>
                </div>
            </div>
            @if (certificates.Count == 0)
            {
                <div class="empty-state">Nenhum certificado emitido ainda.</div>
            }
            else
            {
                <table class="table is-fullwidth is-hoverable is-striped">
                    <thead><tr><th>Nome</th><th>E-mail</th><th>Curso</th><th>Fase</th><th>Horas</th><th>Código</th><th>Emitido em</th></tr></thead>
                    <tbody>
                        @foreach (var c in certificates)
                        {
                            <tr>
                                <td><strong>@c.Name</strong></td>
                                <td>@c.Email</td>
                                <td>@c.Course</td>
                                <td>@c.Phase</td>
                                <td><span class="badge">@c.TotalHours h</span></td>
                                <td style="font-family:monospace;font-size:0.75rem;">@c.ValidationCode</td>
                                <td>@c.IssuedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

    <script>
        let exportJobId = null;
        let exportPollInterval = null;

        function startExport() {
            const btn = document.getElementById('exportBtn');
            const progress = document.getElementById('exportProgress');
            const statusText = document.getElementById('exportStatusText');

            btn.style.display = 'none';
            progress.style.display = 'flex';
            statusText.textContent = 'Iniciando exportação...';
            statusText.className = '';

            fetch('/Admin/StartExport', { method: 'POST' })
                .then(r => r.json())
                .then(data => {
                    if (!data.success) {
                        statusText.textContent = 'Erro: ' + (data.message || 'Falha ao iniciar');
                        statusText.className = 'error-msg';
                        return;
                    }
                    exportJobId = data.jobId;
                    statusText.textContent = 'Gerando certificados...';
                    exportPollInterval = setInterval(pollExport, 2000);
                })
                .catch(err => {
                    statusText.textContent = 'Erro de rede ao iniciar exportação';
                    statusText.className = 'error-msg';
                });
        }

        function pollExport() {
            if (!exportJobId) return;

            fetch('/Admin/ExportStatus?jobId=' + encodeURIComponent(exportJobId))
                .then(r => r.json())
                .then(data => {
                    const statusText = document.getElementById('exportStatusText');

                    if (data.status === 'complete') {
                        clearInterval(exportPollInterval);
                        exportPollInterval = null;
                        statusText.textContent = 'Download iniciado...';
                        // Trigger download
                        window.location.href = '/Admin/DownloadExport?jobId=' + encodeURIComponent(exportJobId);
                        // Reset UI after a moment
                        setTimeout(resetExportUI, 3000);
                    } else if (data.status === 'failed') {
                        clearInterval(exportPollInterval);
                        exportPollInterval = null;
                        statusText.textContent = 'Erro: ' + (data.errorMessage || 'Falha na exportação');
                        statusText.className = 'error-msg';
                        setTimeout(resetExportUI, 5000);
                    }
                    // 'processing' — keep polling
                })
                .catch(err => {
                    // ignore transient errors, keep polling
                });
        }

        function resetExportUI() {
            const btn = document.getElementById('exportBtn');
            const progress = document.getElementById('exportProgress');
            if (btn) btn.style.display = '';
            if (progress) progress.style.display = 'none';
            exportJobId = null;
            if (exportPollInterval) {
                clearInterval(exportPollInterval);
                exportPollInterval = null;
            }
        }
    </script>
</body>
</html>
