@{
    ViewData["Title"] = "Configuração de Certificado";
    Layout = null;
    var config = ViewBag.CertificateConfig as Sasc26.Models.CertificateConfigDto ?? new Sasc26.Models.CertificateConfigDto();
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SASC 26</title>
    <link rel="stylesheet" href="~/css/bulmaswatch.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background: #f5f5f5; min-height: 100vh; }
        .nav-bar { background: #113D76; padding: 16px 24px; display: flex; align-items: center; gap: 16px; }
        .nav-logo { display: flex; align-items: center; gap: 12px; flex: 1; }
        .nav-logo img { height: 32px; }
        .nav-logo h1 { font-size: 1rem; font-weight: 700; color: #fff; margin: 0; }
        .nav-links { display: flex; gap: 16px; align-items: center; }
        .nav-links a { font-size: 0.8rem; color: #2EBDEF; }
        .nav-links a:hover { color: #fff; }
        .nav-links a.nav-logout { color: rgba(255,255,255,0.6); }
        .nav-links a.nav-logout:hover { color: #fff; }
        .container-area { max-width: 800px; margin: 0 auto; padding: 24px 16px; }
        .panel-card { background: #fff; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); padding: 24px; margin-bottom: 20px; }
        .panel-card h2 { font-size: 0.95rem; font-weight: 700; color: #1a1a1a; margin: 0 0 16px; }
        .input:focus, .select select:focus, .textarea:focus { border-color: #2EBDEF; box-shadow: 0 0 0 3px rgba(46,189,239,0.15); }
        .button.is-brand { background-color: #fff; color: #113D76; }
        .button.is-brand:hover { background-color: #f0f0f0; color: #113D76; }
        .button.is-outlined-brand { background-color: transparent; color: #113D76; border: 1px solid #113D76; }
        .button.is-outlined-brand:hover { background-color: #113D76; color: #fff; }
        .button.is-danger-light { background: #fff; color: #dc2626; border: 1px solid #dc2626; }
        .button.is-danger-light:hover { background: #dc2626; color: #fff; }
        .msg-success { background: #ecfdf5; color: #047857; padding: 10px 14px; border-radius: 8px; font-size: 0.85rem; margin-bottom: 12px; }
        .msg-error { background: #fef2f2; color: #b91c1c; padding: 10px 14px; border-radius: 8px; font-size: 0.85rem; margin-bottom: 12px; }
        .hint { font-size: 0.75rem; color: #888; margin-top: 8px; }
        .hint code { background: #f0f0f0; padding: 1px 4px; border-radius: 3px; font-size: 0.72rem; }
        .color-row { display: flex; gap: 16px; align-items: center; margin-top: 12px; }
        .color-field { display: flex; align-items: center; gap: 8px; }
        .color-field label { font-size: 0.8rem; color: #555; min-width: 80px; }
        .color-field input[type="color"] { width: 40px; height: 32px; border: 1px solid #ddd; border-radius: 4px; cursor: pointer; padding: 2px; }
        .bg-preview { max-width: 100%; max-height: 200px; border-radius: 8px; margin-top: 12px; border: 1px solid #eee; }
    </style>
</head>
<body>
    <div class="nav-bar">
        <div class="nav-logo">
            <img src="~/dasc.svg" alt="DASC">
            <h1>Certificados</h1>
        </div>
        <div class="nav-links">
            <a href="/Admin/Dashboard">&#8592; Dashboard</a>
            <a href="/Admin/IssuedCertificates">Emissões</a>
            <a href="/Admin/Logout" class="nav-logout">Sair</a>
        </div>
    </div>

    <div class="container-area">
        <!-- Template message -->
        <div class="panel-card">
            <h2>Mensagem do Certificado</h2>
            <div id="templateMsg"></div>
            <div class="field">
                <label class="label is-small">Template</label>
                <div class="control">
                    <textarea class="textarea" id="templateMessage" rows="4">@config.TemplateMessage</textarea>
                </div>
                <p class="hint">Variáveis: <code>{{nome}}</code> <code>{{email}}</code> <code>{{curso}}</code> <code>{{fase}}</code> <code>{{horas}}</code></p>
            </div>
        </div>

        <!-- Colors -->
        <div class="panel-card">
            <h2>Cores do Certificado</h2>
            <div id="colorsMsg"></div>
            <div class="color-row">
                <div class="color-field">
                    <label>Título</label>
                    <input type="color" id="titleColor" value="@config.TitleColor">
                </div>
                <div class="color-field">
                    <label>Texto</label>
                    <input type="color" id="bodyColor" value="@config.BodyColor">
                </div>
                <div class="color-field">
                    <label>Borda</label>
                    <input type="color" id="borderColor" value="@config.BorderColor">
                </div>
            </div>
        </div>

        <!-- Background image -->
        <div class="panel-card">
            <h2>Imagem de Fundo</h2>
            <div id="bgMsg"></div>
            <p class="hint" style="margin-top:0;margin-bottom:12px;">A imagem será redimensionada para o tamanho do certificado (800 x 600 px recomendado).</p>
            <div id="bgPreviewArea">
                @if (config.HasBackgroundImage)
                {
                    <img src="/Certificate/BackgroundImage" class="bg-preview" alt="Background" id="bgImg">
                }
            </div>
            <div class="field" style="margin-top:12px;">
                <div class="control">
                    <input type="file" id="bgFile" accept="image/*" style="display:none;" onchange="uploadBg()">
                    <button class="button is-brand is-small" onclick="document.getElementById('bgFile').click()">Enviar imagem</button>
                    @if (config.HasBackgroundImage)
                    {
                        <button class="button is-brand is-small" onclick="removeBg()" style="margin-left:8px;">Remover imagem</button>
                    }
                </div>
            </div>
        </div>

        <!-- Save all -->
        <div class="panel-card" style="text-align:center;">
            <button class="button is-brand" onclick="saveAll()">Salvar configurações</button>
        </div>
    </div>

    <script>
        function showMsg(id, t, type) { document.getElementById(id).innerHTML = `<div class="msg-${type}">${t}</div>`; }

        async function saveAll() {
            const templateMessage = document.getElementById('templateMessage').value;
            const titleColor = document.getElementById('titleColor').value;
            const bodyColor = document.getElementById('bodyColor').value;
            const borderColor = document.getElementById('borderColor').value;
            try {
                const res = await fetch('/Admin/UpdateCertificateConfig', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ templateMessage, titleColor, bodyColor, borderColor })
                });
                const data = await res.json();
                if (data.success) showMsg('templateMsg', 'Configurações salvas com sucesso!', 'success');
                else showMsg('templateMsg', 'Erro ao salvar.', 'error');
            } catch { showMsg('templateMsg', 'Erro de conexão.', 'error'); }
        }

        async function uploadBg() {
            const fileInput = document.getElementById('bgFile');
            if (!fileInput.files.length) return;
            const formData = new FormData();
            formData.append('file', fileInput.files[0]);
            try {
                const res = await fetch('/Admin/UploadCertificateBackground', { method: 'POST', body: formData });
                const data = await res.json();
                if (data.success) {
                    showMsg('bgMsg', 'Imagem enviada!', 'success');
                    location.reload();
                } else showMsg('bgMsg', data.message || 'Erro.', 'error');
            } catch { showMsg('bgMsg', 'Erro de conexão.', 'error'); }
        }

        async function removeBg() {
            if (!confirm('Remover a imagem de fundo?')) return;
            try {
                const res = await fetch('/Admin/RemoveCertificateBackground', { method: 'POST' });
                const data = await res.json();
                if (data.success) location.reload();
                else showMsg('bgMsg', 'Erro ao remover.', 'error');
            } catch { showMsg('bgMsg', 'Erro de conexão.', 'error'); }
        }
    </script>
</body>
</html>