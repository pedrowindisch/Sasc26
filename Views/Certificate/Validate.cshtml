@{
    ViewData["Title"] = "Validar Certificado";
    var ev = ViewBag.Event as Sasc26.Models.Event;
    var primaryColor = ev?.PrimaryColor ?? "#113D76";
    var accentColor = ev?.AccentColor ?? "#2EBDEF";
    var backgroundColor = ev?.BackgroundColor ?? "#f5f5f5";
    var eventName = ev?.Name ?? "SASC 26";
    var eventSlug = ev?.Slug ?? "";
}

@section Styles {
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/bulmaswatch.min.css">
    <style>
        body { font-family: 'Inter', sans-serif; background: @backgroundColor; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
        .card-wrapper { width: 100%; max-width: 440px; padding: 0 16px; }
        .event-card { background: #fff; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); overflow: hidden; }
        .event-header { background: @primaryColor; padding: 28px 24px 20px; text-align: center; }
        .event-header img.logo { width: 56px; height: 56px; margin-bottom: 12px; }
        .event-header h1 { font-size: 1.25rem; font-weight: 700; color: #fff; margin: 0; }
        .event-header p { font-size: 0.75rem; color: rgba(255,255,255,0.6); margin: 4px 0 0; text-transform: uppercase; letter-spacing: 0.05em; }
        .event-body { padding: 8px 24px 28px; }
        .step-section { display: none; padding-top: 16px; }
        .step-section.active { display: block; }
        .msg-error { background: #fef2f2; color: #b91c1c; padding: 10px 14px; border-radius: 8px; font-size: 0.85rem; margin-bottom: 16px; }
        .msg-success { background: #ecfdf5; color: #047857; padding: 14px; border-radius: 8px; font-size: 0.85rem; margin-bottom: 16px; line-height: 1.6; }
        .button.is-brand { background-color: #fff; color: @primaryColor; }
        .button.is-brand:hover { background-color: #f0f0f0; color: @primaryColor; }
        .input:focus { border-color: @accentColor; box-shadow: 0 0 0 3px rgba(46,189,239,0.15); }
        .field + .field { margin-top: 12px; }
        .back-link { display: inline-block; margin-top: 12px; font-size: 0.8rem; color: #aaa; cursor: pointer; }
        .back-link:hover { color: #555; }
        .valid-icon { font-size: 2rem; color: #059669; }
    </style>
}

<div class="card-wrapper">
    <div class="event-card">
        <div class="event-header">
            <img class="logo" src="~/dasc.svg" alt="DASC">
            <h1>Validação</h1>
            <p>Autenticidade de Certificado</p>
        </div>
        <div class="event-body">
            <div id="messageArea"></div>

            <div class="step-section active" id="stepValidate">
                <div class="field">
                    <label class="label is-small has-text-grey">E-mail do aluno</label>
                    <div class="control"><input class="input" type="email" id="valEmail" placeholder="seu.nome@furb.br" autocomplete="email" autofocus></div>
                </div>
                <div class="field">
                    <label class="label is-small has-text-grey">Código de validação</label>
                    <div class="control"><input class="input" type="text" id="valCode" placeholder="Ex: A1B2C3D4" style="text-transform:uppercase;"></div>
                </div>
                <div class="field" style="margin-top:16px;">
                    <div class="control"><button class="button is-brand is-fullwidth" id="btnValidate" onclick="validateCert()">Validar</button></div>
                </div>
                <div class="has-text-centered" style="margin-top:12px;">
                    <a href="/@eventSlug/Certificate" class="back-link">Emitir certificado</a>
                </div>
            </div>

            <div class="step-section" id="stepResult">
                <div id="resultArea"></div>
                <div class="has-text-centered" style="margin-top:12px;">
                    <a onclick="resetForm()" class="back-link" style="cursor:pointer;">Validar outro certificado</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
    const baseUrl = '/@eventSlug';
    function showMessage(t, type) { document.getElementById('messageArea').innerHTML = `<div class="msg-${type}">${t}</div>`; }
    function clearMessage() { document.getElementById('messageArea').innerHTML = ''; }
    function showStep(s) { document.querySelectorAll('.step-section').forEach(el => el.classList.remove('active')); document.getElementById('step' + s).classList.add('active'); }

    async function validateCert() {
        const email = document.getElementById('valEmail').value.trim();
        const code = document.getElementById('valCode').value.trim();
        if (!email || !code) { showMessage('Preencha e-mail e código.', 'error'); return; }
        clearMessage();
        const btn = document.getElementById('btnValidate');
        btn.classList.add('is-loading'); btn.disabled = true;
        try {
            const res = await fetch(baseUrl + '/Certificate/DoValidate', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email, validationCode: code }) });
            const data = await res.json();
            if (data.success) {
                const dt = new Date(data.issuedAt).toLocaleString('pt-BR');
                document.getElementById('resultArea').innerHTML = `
                    <div class="msg-success has-text-centered">
                        <div class="valid-icon">&#10003;</div>
                        <strong>${data.message}</strong><br>
                        Emitido para <strong>${data.name}</strong><br>
                        Carga horária: <strong>${data.totalHours} horas</strong><br>
                        E-mail: ${data.email}<br>
                        <span style="font-size:0.75rem;color:#666;">Emitido em: ${dt}</span>
                    </div>`;
            } else {
                document.getElementById('resultArea').innerHTML = `
                    <div class="msg-error has-text-centered">${data.message}</div>`;
            }
            showStep('Result');
        } catch { showMessage('Erro de conexão.', 'error'); }
        finally { btn.classList.remove('is-loading'); btn.disabled = false; }
    }

    function resetForm() { clearMessage(); document.getElementById('valEmail').value = ''; document.getElementById('valCode').value = ''; showStep('Validate'); }

    document.getElementById('valEmail').addEventListener('keydown', e => { if (e.key === 'Enter') validateCert(); });
    document.getElementById('valCode').addEventListener('keydown', e => { if (e.key === 'Enter') validateCert(); });
</script>
}