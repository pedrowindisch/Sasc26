@{
    ViewData["Title"] = "Certificados";
    var ev = ViewBag.Event as Sasc26.Models.Event;
    var primaryColor = ev?.PrimaryColor ?? "#113D76";
    var accentColor = ev?.AccentColor ?? "#2EBDEF";
    var backgroundColor = ev?.BackgroundColor ?? "#f5f5f5";
    var eventName = ev?.Name ?? "SASC 26";
    var eventSubtitle = ev?.Subtitle ?? "";
    var eventSlug = ev?.Slug ?? "";
}

@section Styles {
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/bulmaswatch.min.css">
    <style>
        body { font-family: 'Inter', sans-serif; background: @backgroundColor; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
        .card-wrapper { width: 100%; max-width: 440px; padding: 0 16px; }
        .event-card { background: #fff; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); overflow: hidden; }
        .event-header { background: @primaryColor; padding: 28px 24px 20px; text-align: center; }
        .event-header img.logo { width: 56px; height: 56px; margin-bottom: 12px; }
        .event-header h1 { font-size: 1.25rem; font-weight: 700; color: #fff; margin: 0; }
        .event-header p { font-size: 0.75rem; color: rgba(255,255,255,0.6); margin: 4px 0 0; text-transform: uppercase; letter-spacing: 0.05em; }
        .cert-tag { display: inline-block; margin-top: 12px; padding: 4px 14px; border-radius: 100px; font-size: 0.75rem; font-weight: 600; background: rgba(5,150,105,0.2); color: #059669; }
        .event-body { padding: 8px 24px 28px; }
        .step-section { display: none; padding-top: 16px; }
        .step-section.active { display: block; }
        .msg-error { background: #fef2f2; color: #b91c1c; padding: 10px 14px; border-radius: 8px; font-size: 0.85rem; margin-bottom: 16px; }
        .msg-success { background: #ecfdf5; color: #047857; padding: 10px 14px; border-radius: 8px; font-size: 0.85rem; margin-bottom: 16px; }
        .back-link { display: inline-block; margin-top: 12px; font-size: 0.8rem; color: #aaa; cursor: pointer; }
        .back-link:hover { color: #555; }
        .field + .field { margin-top: 12px; }
        .button.is-brand { background-color: #fff; color: @primaryColor; }
        .button.is-brand:hover { background-color: #f0f0f0; color: @primaryColor; }
        .input:focus, .select select:focus { border-color: @accentColor; box-shadow: 0 0 0 3px rgba(46,189,239,0.15); }

        .fb-header { text-align: center; margin-bottom: 20px; }
        .fb-header h2 { font-size: 0.95rem; font-weight: 700; color: #1a1a1a; margin: 0 0 4px; }
        .fb-header p { font-size: 0.78rem; color: #888; margin: 0; }

        .fb-progress { display: flex; align-items: center; justify-content: center; gap: 6px; margin-bottom: 20px; }
        .fb-progress-dot { width: 8px; height: 8px; border-radius: 50%; background: #e5e7eb; transition: all 0.25s ease; }
        .fb-progress-dot.active { background: @primaryColor; transform: scale(1.25); }
        .fb-progress-dot.done { background: #059669; }
        .fb-progress-dot.skipped { background: #d1d5db; }
        .fb-progress-counter { font-size: 0.7rem; color: #aaa; font-weight: 500; margin-left: 8px; }

        .fb-card { background: #f8fafc; border: 1px solid #e8ecf1; border-radius: 14px; padding: 20px 18px 16px; text-align: center; animation: fbFadeIn 0.3s ease; }
        @@keyframes fbFadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }
        .fb-card .fb-lectitle { font-size: 1rem; font-weight: 700; color: #1a1a1a; margin: 0 0 2px; }
        .fb-card .fb-lecspeaker { font-size: 0.82rem; color: #8896a7; margin: 0 0 16px; }

        .fb-stars { display: flex; gap: 8px; justify-content: center; margin-bottom: 14px; }
        .fb-stars .fb-star { font-size: 2.2rem; cursor: pointer; color: #dde3eb; transition: color 0.15s, transform 0.12s; user-select: none; line-height: 1; }
        .fb-stars .fb-star.active { color: #f59e0b; }
        .fb-stars .fb-star:hover { color: #fbbf24; transform: scale(1.18); }

        .fb-comment { margin-top: 2px; }
        .fb-comment .input { background: #fff; border-color: #e0e5ec; font-size: 0.85rem; }
        .fb-comment .input::placeholder { color: #b0b8c4; }

        .fb-skipped-badge { display: inline-block; background: #f3f4f6; color: #9ca3af; font-size: 0.72rem; font-weight: 600; padding: 3px 10px; border-radius: 100px; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.04em; }

        .fb-actions { display: flex; flex-direction: column-reverse; gap: 8px; margin-top: 20px; }
        .fb-actions .button { width: 100%; }

        .ty-message { font-size: 0.92rem; color: #333; line-height: 1.6; text-align: center; margin-bottom: 20px; }
        .ty-form { background: #f8fafc; border: 1px solid #e8ecf1; border-radius: 12px; padding: 18px 16px; margin-top: 8px; }
        .ty-form h3 { font-size: 0.9rem; font-weight: 700; color: #1a1a1a; margin: 0 0 4px; }
        .ty-form p { font-size: 0.78rem; color: #888; margin: 0 0 14px; }
        .ty-actions { margin-top: 16px; }
        .ty-skip { text-align: center; margin-top: 8px; }
        .ty-skip a { font-size: 0.78rem; color: #aaa; cursor: pointer; }
        .ty-skip a:hover { color: #555; }
    </style>
}

<div class="card-wrapper">
    <div class="event-card">
        <div class="event-header">
            <img class="logo" src="~/dasc.svg" alt="DASC">
            <h1>@eventName</h1>
            <p>@eventSubtitle</p>
            <span class="cert-tag">Certificados</span>
        </div>

        <div class="event-body">
            <div id="messageArea"></div>

            <div class="step-section active" id="stepEmail">
                <div class="field">
                    <label class="label is-small has-text-grey">E-mail institucional (@@furb.br)</label>
                    <div class="control"><input class="input" type="email" id="emailInput" placeholder="seu.nome@furb.br" autocomplete="email" autofocus></div>
                </div>
                <div class="field" style="margin-top:16px;">
                    <div class="control"><button class="button is-brand is-fullwidth" id="btnLookup" onclick="lookupEmail()">Buscar certificado</button></div>
                </div>
                <div class="has-text-centered" style="margin-top:12px;">
                    <a href="/@eventSlug" class="back-link">Voltar ao site</a>
                    <span style="color:#ddd;margin:0 6px;">|</span>
                    <a href="/@eventSlug/Certificate/Validate" class="back-link">Validar certificado</a>
                </div>
            </div>

            <div class="step-section" id="stepProfile"></div>
                <p style="font-size:0.85rem;color:#666;margin-bottom:12px;">Complete seu perfil para emitir o certificado:</p>
                <div class="field"><label class="label is-small has-text-grey">Nome completo</label><div class="control"><input class="input" type="text" id="profileName" placeholder="João da Silva"></div></div>
                <div class="field"><label class="label is-small has-text-grey">Curso</label><div class="control"><div class="select is-fullwidth"><select id="profileCourse"><option value="">Selecione</option><option value="Ciência da Computação">Ciência da Computação</option><option value="Ciência de Dados">Ciência de Dados</option><option value="Sistemas de Informação">Sistemas de Informação</option></select></div></div></div>
                <div class="field"><label class="label is-small has-text-grey">Fase</label><div class="control"><div class="select is-fullwidth"><select id="profilePhase"><option value="">-</option>@for (var i = 1; i <= 9; i++) {<option value="@i">@i</option>}</select></div></div></div>
                <div class="field" style="margin-top:16px;"><div class="control"><button class="button is-brand is-fullwidth" id="btnIssue" onclick="issueCertificate()">Emitir certificado</button></div></div>
                <a class="back-link" onclick="goBack()">&#8592; Voltar</a>
            </div>

            <div class="step-section" id="stepFeedback">
                <div class="fb-header">
                    <h2>Avaliação das Palestras</h2>
                    <p>Responda com sinceridade. Caso não queira responder, pule.</p>
                </div>
                <div class="fb-progress" id="fbProgress"></div>
                <div id="fbCard"></div>
                <div class="fb-actions">
                    <button class="button is-brand is-fullwidth" id="btnNext" onclick="fbNext()">Próximo &#8594;</button>
                    <button class="button is-brand is-fullwidth" id="btnSkip" onclick="fbSkip()">Pular avaliação</button>
                    <button class="button is-brand is-fullwidth" id="btnPrev" onclick="fbPrev()" style="display:none;">&#8592; Anterior</button>
                </div>
            </div>

            <div class="step-section" id="stepThankYou">
                <div class="ty-message" id="tyMessage"></div>
                <div id="tyFormArea"></div>
                <div class="ty-actions">
                    <button class="button is-brand is-fullwidth" id="btnTySubmit" onclick="tySubmit()">Continuar</button>
                </div>
                <div class="ty-skip" id="tySkipArea" style="display:none;">
                    <a onclick="tySkip()">Pular e emitir certificado</a>
                </div>
            </div>

            <div class="step-section" id="stepSuccess">
                <div class="msg-success has-text-centered" id="successMessage"></div>
                <div class="has-text-centered" style="margin-top:12px;">
                    <a id="certLink" href="#" class="button is-brand is-fullwidth" target="_blank" rel="noopener">Visualizar / Imprimir certificado</a>
                </div>
                <div class="has-text-centered" style="margin-top:8px;">
                    <a href="/@eventSlug/Certificate/Validate" class="back-link">Validar certificado</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
    const baseUrl = '/@eventSlug';
    let currentEmail = '';
    let pendingLectures = [];
    let wizData = [];
    let wizIdx = 0;
    let tyConfig = null;

    function showMessage(t, type) { document.getElementById('messageArea').innerHTML = `<div class="msg-${type}">${t}</div>`; }
    function clearMessage() { document.getElementById('messageArea').innerHTML = ''; }
    function showStep(s) { document.querySelectorAll('.step-section').forEach(el => el.classList.remove('active')); document.getElementById('step' + s).classList.add('active'); }
    function esc(s) { const d = document.createElement('div'); d.textContent = s || ''; return d.innerHTML; }
    function escA(s) { return (s||'').replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;'); }

    async function lookupEmail() {
        const email = document.getElementById('emailInput').value.trim();
        if (!email) { showMessage('Informe o e-mail.', 'error'); return; }
        clearMessage();
        const btn = document.getElementById('btnLookup');
        btn.classList.add('is-loading'); btn.disabled = true;
        try {
            const res = await fetch(baseUrl + '/Certificate/Lookup', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email }) });
            const data = await res.json();
            if (!data.success) { showMessage(data.message, 'error'); }
            else {
                currentEmail = email;
                if (data.exists) { document.getElementById('profileName').value = data.name || ''; document.getElementById('profileCourse').value = data.course || ''; document.getElementById('profilePhase').value = data.phase || ''; }
                else { document.getElementById('profileName').value = ''; document.getElementById('profileCourse').value = ''; document.getElementById('profilePhase').value = ''; }
                showStep('Profile');
            }
        } catch { showMessage('Erro de conexão.', 'error'); }
        finally { btn.classList.remove('is-loading'); btn.disabled = false; }
    }

    async function issueCertificate() {
        const name = document.getElementById('profileName').value.trim();
        const course = document.getElementById('profileCourse').value;
        const phase = document.getElementById('profilePhase').value;
        if (!name) { showMessage('Informe seu nome.', 'error'); return; }
        if (!course) { showMessage('Selecione o curso.', 'error'); return; }
        if (!phase) { showMessage('Selecione a fase.', 'error'); return; }
        clearMessage();
        const btn = document.getElementById('btnIssue');
        btn.classList.add('is-loading'); btn.disabled = true;
        try {
            const fbRes = await fetch(baseUrl + '/Certificate/CheckFeedbackStatus', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email: currentEmail }) });
            const fbData = await fbRes.json();
            if (fbData.needsFeedback && fbData.lectures && fbData.lectures.length > 0) {
                pendingLectures = fbData.lectures;
                initFb();
                showStep('Feedback');
            } else {
                await checkThankYou();
            }
        } catch { showMessage('Erro de conexão.', 'error'); }
        finally { btn.classList.remove('is-loading'); btn.disabled = false; }
    }

    async function doIssue(name, course, phase) {
        try {
            const res = await fetch(baseUrl + '/Certificate/Issue', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email: currentEmail, name, course, phase }) });
            const data = await res.json();
            if (data.success) {
                document.getElementById('successMessage').textContent = data.message || 'Certificado emitido com sucesso!';
                document.getElementById('certLink').href = baseUrl + '/Certificate/Print?code=' + encodeURIComponent(data.validationCode);
                showStep('Success');
            } else { showMessage(data.message, 'error'); }
        } catch { showMessage('Erro de conexão.', 'error'); }
    }

    async function checkThankYou() {
        try {
            const res = await fetch(baseUrl + '/Certificate/GetThankYouConfig');
            const data = await res.json();
            if (data.success && data.config && data.config.message) {
                tyConfig = data.config;
                renderThankYou();
                showStep('ThankYou');
            } else {
                const name = document.getElementById('profileName').value.trim();
                const course = document.getElementById('profileCourse').value;
                const phase = document.getElementById('profilePhase').value;
                await doIssue(name, course, phase);
            }
        } catch {
            const name = document.getElementById('profileName').value.trim();
            const course = document.getElementById('profileCourse').value;
            const phase = document.getElementById('profilePhase').value;
            await doIssue(name, course, phase);
        }
    }

    function initFb() {
        wizData = pendingLectures.map(l => ({ lectureId: l.lectureId, title: l.title, speaker: l.speaker, rating: 0, comment: '', skipped: false }));
        wizIdx = 0;
        renderFb();
    }

    function renderFb() {
        const total = wizData.length;
        const lec = wizData[wizIdx];
        document.getElementById('messageArea').innerHTML = '';

        const dots = wizData.map((w, i) => {
            let cls = 'fb-progress-dot';
            if (i === wizIdx) cls += ' active';
            else if (w.skipped) cls += ' skipped';
            else if (w.rating > 0) cls += ' done';
            return `<span class="${cls}"></span>`;
        }).join('');
        document.getElementById('fbProgress').innerHTML = dots + `<span class="fb-progress-counter">${wizIdx + 1}/${total}</span>`;

        if (lec.skipped) {
            document.getElementById('fbCard').innerHTML = `
                <div class="fb-card" style="opacity:0.55;">
                    <span class="fb-skipped-badge">Avaliação pulada</span>
                    <p class="fb-lectitle">${esc(lec.title)}</p>
                    <p class="fb-lecspeaker">${esc(lec.speaker)}</p>
                </div>`;
        } else {
            document.getElementById('fbCard').innerHTML = `
                <div class="fb-card">
                    <p class="fb-lectitle">${esc(lec.title)}</p>
                    <p class="fb-lecspeaker">${esc(lec.speaker)}</p>
                    <div class="fb-stars" id="fbStars">
                        ${[1,2,3,4,5].map(s => `<span class="fb-star ${lec.rating >= s ? 'active' : ''}" onclick="fbRate(${s})">&#9733;</span>`).join('')}
                    </div>
                    <div class="fb-comment">
                        <input class="input is-small" type="text" id="fbComment" placeholder="Comentário (opcional)" maxlength="500" value="${escA(lec.comment)}">
                    </div>
                </div>`;
        }

        document.getElementById('btnPrev').style.display = wizIdx > 0 ? '' : 'none';
        document.getElementById('btnSkip').style.display = lec.skipped ? 'none' : '';

        const btnNext = document.getElementById('btnNext');
        btnNext.textContent = wizIdx === total - 1 ? 'Enviar e emitir certificado' : 'Próximo \u2192';
        btnNext.classList.remove('is-loading');
        btnNext.disabled = false;
    }

    function fbRate(val) {
        wizData[wizIdx].rating = val;
        wizData[wizIdx].skipped = false;
        renderFb();
    }

    function fbSkip() {
        wizData[wizIdx].rating = 0;
        wizData[wizIdx].skipped = true;
        saveComment();
        renderFb();
    }

    function saveComment() {
        const el = document.getElementById('fbComment');
        if (el) wizData[wizIdx].comment = el.value.trim();
    }

    function fbPrev() {
        saveComment();
        if (wizIdx > 0) { wizIdx--; renderFb(); }
    }

    function fbNext() {
        saveComment();
        const lec = wizData[wizIdx];
        if (!lec.skipped && lec.rating === 0) { showMessage('Selecione uma nota ou pule esta avaliação.', 'error'); return; }
        clearMessage();
        if (wizIdx < wizData.length - 1) { wizIdx++; renderFb(); }
        else { submitFeedback(); }
    }

    async function submitFeedback() {
        const btn = document.getElementById('btnNext');
        btn.classList.add('is-loading'); btn.disabled = true;
        try {
            const feedbacks = wizData.map(w => ({ lectureId: w.lectureId, rating: w.rating, comment: w.comment, skipped: w.skipped }));
            await fetch(baseUrl + '/Feedback/Submit', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email: currentEmail, feedbacks }) });
            await checkThankYou();
        } catch { showMessage('Erro ao enviar feedback.', 'error'); btn.classList.remove('is-loading'); btn.disabled = false; }
    }

    function renderThankYou() {
        clearMessage();
        const msgEl = document.getElementById('tyMessage');
        msgEl.innerHTML = esc(tyConfig.message).replace(/\n/g, '<br>');

        const formArea = document.getElementById('tyFormArea');
        const skipArea = document.getElementById('tySkipArea');
        const submitBtn = document.getElementById('btnTySubmit');

        if (tyConfig.isFormEnabled && tyConfig.formFields && tyConfig.formFields.length > 0) {
            let formHtml = '<div class="ty-form">';
            formHtml += `<h3>${esc(tyConfig.formTitle || 'Formulário')}</h3>`;
            if (tyConfig.formDescription) formHtml += `<p>${esc(tyConfig.formDescription)}</p>`;
            tyConfig.formFields.forEach((f, i) => {
                const req = f.required ? '<span style="color:#b91c1c;">*</span>' : '';
                formHtml += `<div class="field"><label class="label is-small has-text-grey">${esc(f.label)} ${req}</label>`;
                if (f.type === 'select') {
                    formHtml += `<div class="control"><div class="select is-fullwidth is-small"><select id="tyField_${i}"><option value="">Selecione</option>`;
                    (f.options || []).forEach(o => { formHtml += `<option value="${escA(o)}">${esc(o)}</option>`; });
                    formHtml += '</select></div></div>';
                } else if (f.type === 'textarea') {
                    formHtml += `<div class="control"><textarea class="textarea is-small" id="tyField_${i}" rows="3" placeholder="${escA(f.placeholder || '')}"></textarea></div>`;
                } else {
                    formHtml += `<div class="control"><input class="input is-small" type="${f.type === 'email' ? 'email' : 'text'}" id="tyField_${i}" placeholder="${escA(f.placeholder || '')}"></div>`;
                }
                formHtml += '</div>';
            });
            formHtml += '</div>';
            formArea.innerHTML = formHtml;
            submitBtn.textContent = tyConfig.formButtonText || 'Enviar';
            skipArea.style.display = '';
        } else {
            formArea.innerHTML = '';
            submitBtn.textContent = 'Continuar';
            skipArea.style.display = 'none';
        }
    }

    async function tySubmit() {
        const btn = document.getElementById('btnTySubmit');
        btn.classList.add('is-loading'); btn.disabled = true;
        try {
            if (tyConfig.isFormEnabled && tyConfig.formFields && tyConfig.formFields.length > 0) {
                const responses = [];
                let valid = true;
                tyConfig.formFields.forEach((f, i) => {
                    const el = document.getElementById('tyField_' + i);
                    const val = el ? el.value.trim() : '';
                    if (f.required && !val) { valid = false; }
                    responses.push({ label: f.label, value: val });
                });
                if (!valid) { showMessage('Preencha os campos obrigatórios.', 'error'); btn.classList.remove('is-loading'); btn.disabled = false; return; }
                await fetch(baseUrl + '/Certificate/SubmitForm', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email: currentEmail, responses }) });
            }
            const name = document.getElementById('profileName').value.trim();
            const course = document.getElementById('profileCourse').value;
            const phase = document.getElementById('profilePhase').value;
            await doIssue(name, course, phase);
        } catch { showMessage('Erro ao enviar formulário.', 'error'); btn.classList.remove('is-loading'); btn.disabled = false; }
    }

    async function tySkip() {
        const name = document.getElementById('profileName').value.trim();
        const course = document.getElementById('profileCourse').value;
        const phase = document.getElementById('profilePhase').value;
        await doIssue(name, course, phase);
    }

    function goBack() { clearMessage(); showStep('Email'); }
    document.getElementById('emailInput').addEventListener('keydown', e => { if (e.key === 'Enter') lookupEmail(); });
</script>
}